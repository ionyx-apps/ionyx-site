---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="Blog | Ionyx Framework" description="Latest news, updates and guides for Ionyx Framework">
	<main class="relative pt-32 pb-24 overflow-hidden">
		<!-- Background Elements -->
		<div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full -z-10 pointer-events-none">
			<div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-purple-900/20 blur-[120px] rounded-full"></div>
			<div class="absolute bottom-[10%] right-[-10%] w-[40%] h-[40%] bg-blue-900/20 blur-[120px] rounded-full"></div>
		</div>

		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<!-- Header -->
			<div class="text-center mb-20">
				<h1 class="text-5xl md:text-6xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-white via-purple-300 to-blue-300 mb-6">
					Blog & Updates
				</h1>
				<p class="text-xl text-gray-400 max-w-2xl mx-auto">
					Stay up to date with the latest features, tutorials, and community news from the Ionyx ecosystem.
				</p>
			</div>

			<!-- Blog Grid -->
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
				{posts.map((post) => {
					const slug = post.id.replace(/\.[^/.]+$/, "");
					return (
						<article class="group relative bg-gray-900/50 border border-gray-800 rounded-2xl overflow-hidden hover:border-purple-500/50 transition-all duration-300 transform hover:-translate-y-2">
							<a href={`/blog/${slug}`} class="block h-full">
								<div class="aspect-video relative overflow-hidden bg-gray-800">
								{post.data.heroImage ? (
									<div class="w-full h-full bg-gradient-to-br from-purple-600/20 to-blue-600/20 flex items-center justify-center text-4xl">
										🚀
									</div>
								) : (
									<div class="w-full h-full bg-gradient-to-br from-purple-600/20 to-blue-600/20 flex items-center justify-center text-4xl">
										📄
									</div>
								)}
								<div class="absolute inset-0 bg-gradient-to-t from-gray-900 via-transparent to-transparent opacity-60"></div>
							</div>
							
							<div class="p-8">
								<div class="flex items-center space-x-2 text-sm text-purple-400 mb-4">
									<time datetime={post.data.pubDate.toISOString()}>
										{post.data.pubDate.toLocaleDateString('en-us', {
											year: 'numeric',
											month: 'short',
											day: 'numeric',
										})}
									</time>
									<span>•</span>
									<span>{post.data.description.split(' ').length > 15 ? '5 min read' : '2 min read'}</span>
								</div>
								
								<h2 class="text-2xl font-bold text-white mb-4 group-hover:text-purple-300 transition-colors">
									{post.data.title}
								</h2>
								
								<p class="text-gray-400 mb-6 line-clamp-3">
									{post.data.description}
								</p>
								
								<div class="mt-auto flex items-center text-white font-medium group-hover:text-purple-400 transition-colors">
									Read More 
									<svg class="w-5 h-5 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
									</svg>
								</div>
							</div>
						</a>
					</article>
					);
				})}
			</div>

			<!-- Newsletter Section -->
			<div class="mt-32 relative rounded-3xl overflow-hidden bg-gradient-to-br from-purple-900/20 to-blue-900/20 border border-white/10 p-12 text-center backdrop-blur-sm">
				<h2 class="text-3xl font-bold text-white mb-6">Want more Ionyx news?</h2>
				<p class="text-gray-400 mb-8 max-w-xl mx-auto">
					Join our newsletter to receive the latest updates, tutorials, and early access to new features.
				</p>
				<form class="flex flex-col sm:flex-row gap-4 max-w-md mx-auto">
					<input 
						type="email" 
						placeholder="Enter your email" 
						class="flex-1 px-6 py-4 rounded-xl bg-gray-900/50 border border-gray-700 text-white focus:outline-none focus:border-purple-500 transition-colors"
					/>
					<button class="bg-gradient-to-r from-purple-600 to-blue-600 text-white px-8 py-4 rounded-xl font-bold hover:from-purple-700 hover:to-blue-700 transition-all shadow-lg hover:shadow-purple-500/25">
						Subscribe
					</button>
				</form>
			</div>
		</div>
	</main>
</Layout>
