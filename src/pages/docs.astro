---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Documentation - Ionyx Framework">
	<!-- Hero Section -->
	<section class="relative min-h-screen flex items-center justify-center overflow-hidden hero-gradient">
		<div class="absolute inset-0 overflow-hidden">
			<div class="absolute -top-40 -right-40 w-96 h-96 bg-gradient-to-br from-purple-500/20 to-transparent rounded-full blur-3xl animate-pulse"></div>
			<div class="absolute -bottom-40 -left-40 w-96 h-96 bg-gradient-to-br from-blue-500/20 to-transparent rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
			<div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-gradient-to-br from-pink-500/20 to-transparent rounded-full blur-3xl animate-pulse" style="animation-delay: 2s;"></div>
		</div>
		
		<div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<div class="inline-flex items-center px-4 py-2 glass px-4 py-2 rounded-full mb-8">
				<span class="text-sm text-gray-300">📚 Comprehensive Documentation</span>
			</div>
			
			<h1 class="text-5xl md:text-7xl lg:text-8xl font-bold text-white mb-6 leading-tight">
				<span class="bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue bg-clip-text text-transparent">Documentation</span>
			</h1>
			
			<p class="text-xl md:text-2xl text-gray-300 mb-8 max-w-3xl mx-auto leading-relaxed">
				Complete guides, API reference, and examples for building desktop applications with Ionyx Framework.
			</p>
			
			<div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
				<a href="/docs/introduction" class="group relative inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-white bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue rounded-lg hover:from-ionyx-neon-purple/80 hover:to-ionyx-neon-blue/80 transform hover:-translate-y-1 transition-all duration-300 shadow-lg hover:shadow-ionyx-neon-purple/25">
					<span class="relative z-10">Get Started</span>
					<div class="absolute inset-0 bg-gradient-to-r from-purple-600 to-blue-600 rounded-lg blur opacity-75 group-hover:opacity-100 transition-opacity"></div>
				</a>
				<a href="https://github.com/ionyx-apps/ionyx-cli/tree/main/docs" class="group relative inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-white border border-gray-600 rounded-lg hover:bg-gray-800/50 transform hover:-translate-y-1 transition-all duration-300 backdrop-blur-sm">
					<span class="relative z-10">View on GitHub</span>
				</a>
			</div>
		</div>
	</section>

	<!-- Quick Links -->
	<section class="relative py-20 bg-gradient-to-br from-gray-900 via-purple-900/50 to-gray-900">
		<div class="absolute inset-0 overflow-hidden">
			<div class="absolute -top-20 -right-20 w-64 h-64 bg-gradient-to-br from-purple-500/10 to-transparent rounded-full blur-3xl animate-pulse"></div>
			<div class="absolute -bottom-20 -left-20 w-64 h-64 bg-gradient-to-br from-blue-500/10 to-transparent rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
		</div>
		
		<div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-16">
				<h2 class="text-4xl font-bold bg-gradient-to-r from-blue-400 via-purple-400 to-pink-400 bg-clip-text text-transparent mb-4">
					Quick Links
				</h2>
				<p class="text-gray-300 text-lg">
					Find exactly what you need to get started with Ionyx Framework
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
				<!-- Getting Started -->
				<div class="group relative bg-white/10 backdrop-blur-sm border border-purple-500/30 rounded-xl p-6 hover:bg-purple-500/10 transition-all duration-300 hover:-translate-y-2">
					<div class="absolute inset-0 bg-gradient-to-r from-purple-600/20 to-blue-600/20 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
					<div class="relative z-10">
						<div class="w-12 h-12 bg-gradient-to-r from-purple-500 to-blue-500 rounded-lg flex items-center justify-center mb-4">
							<span class="text-2xl">🚀</span>
						</div>
						<h3 class="text-xl font-semibold text-white mb-2">Getting Started</h3>
						<p class="text-gray-300 mb-4">
							Quick setup and your first Ionyx application
						</p>
						<a href="#getting-started" class="inline-flex items-center text-purple-400 hover:text-purple-300 transition-colors">
							Read More →
						</a>
					</div>
				</div>

				<!-- API Reference -->
				<div class="group relative bg-white/10 backdrop-blur-sm border border-blue-500/30 rounded-xl p-6 hover:bg-blue-500/10 transition-all duration-300 hover:-translate-y-2">
					<div class="absolute inset-0 bg-gradient-to-r from-blue-600/20 to-cyan-600/20 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
					<div class="relative z-10">
						<div class="w-12 h-12 bg-gradient-to-r from-blue-500 to-cyan-500 rounded-lg flex items-center justify-center mb-4">
							<span class="text-2xl">🔧</span>
						</div>
						<h3 class="text-xl font-semibold text-white mb-2">API Reference</h3>
						<p class="text-gray-300 mb-4">
							Complete API documentation and examples
						</p>
						<a href="#api-reference" class="inline-flex items-center text-blue-400 hover:text-blue-300 transition-colors">
							Read More →
						</a>
					</div>
				</div>

				<!-- Frontend Guides -->
				<div class="group relative bg-white/10 backdrop-blur-sm border border-green-500/30 rounded-xl p-6 hover:bg-green-500/10 transition-all duration-300 hover:-translate-y-2">
					<div class="absolute inset-0 bg-gradient-to-r from-green-600/20 to-emerald-600/20 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
					<div class="relative z-10">
						<div class="w-12 h-12 bg-gradient-to-r from-green-500 to-emerald-500 rounded-lg flex items-center justify-center mb-4">
							<span class="text-2xl">⚛️</span>
						</div>
						<h3 class="text-xl font-semibold text-white mb-2">Frontend Guides</h3>
						<p class="text-gray-300 mb-4">
							React, Vue, Svelte, and vanilla JS integration
						</p>
						<a href="#frontend-guides" class="inline-flex items-center text-green-400 hover:text-green-300 transition-colors">
							Read More →
						</a>
					</div>
				</div>

				<!-- Backend Development -->
				<div class="group relative bg-white/10 backdrop-blur-sm border border-orange-500/30 rounded-xl p-6 hover:bg-orange-500/10 transition-all duration-300 hover:-translate-y-2">
					<div class="absolute inset-0 bg-gradient-to-r from-orange-600/20 to-red-600/20 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
					<div class="relative z-10">
						<div class="w-12 h-12 bg-gradient-to-r from-orange-500 to-red-500 rounded-lg flex items-center justify-center mb-4">
							<span class="text-2xl">🦀</span>
						</div>
						<h3 class="text-xl font-semibold text-white mb-2">Backend Development</h3>
						<p class="text-gray-300 mb-4">
							Rust backend development and IPC communication
						</p>
						<a href="#backend-guides" class="inline-flex items-center text-orange-400 hover:text-orange-300 transition-colors">
							Read More →
						</a>
					</div>
				</div>

				<!-- Configuration -->
				<div class="group relative bg-white/10 backdrop-blur-sm border border-pink-500/30 rounded-xl p-6 hover:bg-pink-500/10 transition-all duration-300 hover:-translate-y-2">
					<div class="absolute inset-0 bg-gradient-to-r from-pink-600/20 to-rose-600/20 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
					<div class="relative z-10">
						<div class="w-12 h-12 bg-gradient-to-r from-pink-500 to-rose-500 rounded-lg flex items-center justify-center mb-4">
							<span class="text-2xl">⚙️</span>
						</div>
						<h3 class="text-xl font-semibold text-white mb-2">Configuration</h3>
						<p class="text-gray-300 mb-4">
							ionyx.config.toml and all configuration options
						</p>
						<a href="#configuration" class="inline-flex items-center text-pink-400 hover:text-pink-300 transition-colors">
							Read More →
						</a>
					</div>
				</div>

				<!-- Deployment -->
				<div class="group relative bg-white/10 backdrop-blur-sm border border-cyan-500/30 rounded-xl p-6 hover:bg-cyan-500/10 transition-all duration-300 hover:-translate-y-2">
					<div class="absolute inset-0 bg-gradient-to-r from-cyan-600/20 to-teal-600/20 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
					<div class="relative z-10">
						<div class="w-12 h-12 bg-gradient-to-r from-cyan-500 to-teal-500 rounded-lg flex items-center justify-center mb-4">
							<span class="text-2xl">🚀</span>
						</div>
						<h3 class="text-xl font-semibold text-white mb-2">Deployment</h3>
						<p class="text-gray-300 mb-4">
							Build, package, and distribute your applications
						</p>
						<a href="#deployment" class="inline-flex items-center text-cyan-400 hover:text-cyan-300 transition-colors">
							Read More →
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Getting Started Section -->
	<section id="getting-started" class="relative py-20 bg-gradient-to-br from-gray-900 via-blue-900/50 to-gray-900">
		<div class="absolute inset-0 overflow-hidden">
			<div class="absolute -top-20 -right-20 w-64 h-64 bg-gradient-to-br from-blue-500/10 to-transparent rounded-full blur-3xl animate-pulse"></div>
			<div class="absolute -bottom-20 -left-20 w-64 h-64 bg-gradient-to-br from-purple-500/10 to-transparent rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
		</div>
		
		<div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-16">
				<h2 class="text-4xl font-bold bg-gradient-to-r from-blue-400 via-purple-400 to-pink-400 bg-clip-text text-transparent mb-4">
					Getting Started
				</h2>
				<p class="text-gray-300 text-lg">
					Everything you need to know to start building with Ionyx Framework
				</p>
			</div>

			<div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
				<div class="space-y-8">
					<div class="bg-white/10 backdrop-blur-sm border border-blue-500/30 rounded-xl p-6">
						<h3 class="text-xl font-semibold text-white mb-4">📋 Prerequisites</h3>
						<ul class="space-y-2 text-gray-300">
							<li>• Rust 1.70+ (latest stable)</li>
							<li>• Node.js 18+ or newer</li>
							<li>• npm 8+ or newer</li>
							<li>• Cargo (Rust package manager)</li>
						</ul>
					</div>

					<div class="bg-white/10 backdrop-blur-sm border border-purple-500/30 rounded-xl p-6">
						<h3 class="text-xl font-semibold text-white mb-4">🚀 Installation</h3>
						<div class="space-y-4">
							<div class="bg-black/50 rounded-lg p-4">
								<code class="text-green-400">npm install -g ionyx</code>
							</div>
							<div class="bg-black/50 rounded-lg p-4">
								<code class="text-green-400">npx ionyx create my-app</code>
							</div>
						</div>
					</div>
				</div>

				<div class="space-y-8">
					<div class="bg-white/10 backdrop-blur-sm border border-green-500/30 rounded-xl p-6">
						<h3 class="text-xl font-semibold text-white mb-4">🎯 First Steps</h3>
						<div class="space-y-4">
							<div class="bg-black/50 rounded-lg p-4">
								<code class="text-green-400">cd my-app</code>
							</div>
							<div class="bg-black/50 rounded-lg p-4">
								<code class="text-green-400">ionyx dev</code>
							</div>
						</div>
					</div>

					<div class="bg-white/10 backdrop-blur-sm border border-orange-500/30 rounded-xl p-6">
						<h3 class="text-xl font-semibold text-white mb-4">📁 Project Structure</h3>
						<div class="bg-black/50 rounded-lg p-4">
							<code class="text-green-400 text-sm">
my-app/<br/>
├── src-ionyx/     # Rust backend<br/>
├── frontend/      # Frontend app<br/>
├── common/        # Shared code<br/>
└── ionyx.config.toml
							</code>
						</div>
					</div>
				</div>
			</div>

			<div class="text-center mt-12">
				<a href="https://github.com/ionyx-apps/ionyx-cli/blob/main/docs/getting-started.md" class="group relative inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-white bg-gradient-to-r from-blue-600 to-purple-600 rounded-lg hover:from-blue-700 hover:to-purple-700 transform hover:-translate-y-1 transition-all duration-300 shadow-lg hover:shadow-blue-500/25">
					<span class="relative z-10">📖 Read Full Getting Started Guide</span>
					<div class="absolute inset-0 bg-gradient-to-r from-blue-600 to-purple-600 rounded-lg blur opacity-75 group-hover:opacity-100 transition-opacity"></div>
				</a>
			</div>
		</div>
	</section>

	<!-- API Reference Section -->
	<section id="api-reference" class="relative py-20 bg-gradient-to-br from-gray-900 via-purple-900/50 to-gray-900">
		<div class="absolute inset-0 overflow-hidden">
			<div class="absolute -top-20 -right-20 w-64 h-64 bg-gradient-to-br from-purple-500/10 to-transparent rounded-full blur-3xl animate-pulse"></div>
			<div class="absolute -bottom-20 -left-20 w-64 h-64 bg-gradient-to-br from-blue-500/10 to-transparent rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
		</div>
		
		<div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-16">
				<h2 class="text-4xl font-bold bg-gradient-to-r from-purple-400 via-blue-400 to-pink-400 bg-clip-text text-transparent mb-4">
					API Reference
				</h2>
				<p class="text-gray-300 text-lg">
					Complete API documentation for frontend and backend development
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
				<div class="bg-white/10 backdrop-blur-sm border border-purple-500/30 rounded-xl p-6">
					<h3 class="text-xl font-semibold text-white mb-4">🌐 Frontend API</h3>
					<div class="space-y-4">
						<div class="bg-black/50 rounded-lg p-4">
							<code class="text-green-400 text-sm">
// IPC Communication<br/>
await window.ionyx.invoke('command', payload);
							</code>
						</div>
						<div class="bg-black/50 rounded-lg p-4">
							<code class="text-green-400 text-sm">
// Event Listening<br/>
window.ionyx.on('event', callback);
							</code>
						</div>
					</div>
				</div>

				<div class="bg-white/10 backdrop-blur-sm border border-blue-500/30 rounded-xl p-6">
					<h3 class="text-xl font-semibold text-white mb-4">🦀 Backend API</h3>
					<div class="space-y-4">
						<div class="bg-black/50 rounded-lg p-4">
							<code class="text-green-400 text-sm">
// Command Handler<br/>
bridge.on('command', handler);
							</code>
						</div>
						<div class="bg-black/50 rounded-lg p-4">
							<code class="text-green-400 text-sm">
// Event Emission<br/>
bridge.emit('event', data);
							</code>
						</div>
					</div>
				</div>
			</div>

			<div class="text-center mt-12">
				<a href="https://github.com/ionyx-apps/ionyx-cli/blob/main/docs/api-reference.md" class="group relative inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-white bg-gradient-to-r from-purple-600 to-blue-600 rounded-lg hover:from-purple-700 hover:to-blue-700 transform hover:-translate-y-1 transition-all duration-300 shadow-lg hover:shadow-purple-500/25">
					<span class="relative z-10">🔧 View Complete API Reference</span>
					<div class="absolute inset-0 bg-gradient-to-r from-purple-600 to-blue-600 rounded-lg blur opacity-75 group-hover:opacity-100 transition-opacity"></div>
				</a>
			</div>
		</div>
	</section>

	<!-- Frontend Guides Section -->
	<section id="frontend-guides" class="relative py-20 bg-gradient-to-br from-gray-900 via-green-900/50 to-gray-900">
		<div class="absolute inset-0 overflow-hidden">
			<div class="absolute -top-20 -right-20 w-64 h-64 bg-gradient-to-br from-green-500/10 to-transparent rounded-full blur-3xl animate-pulse"></div>
			<div class="absolute -bottom-20 -left-20 w-64 h-64 bg-gradient-to-br from-blue-500/10 to-transparent rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
		</div>
		
		<div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-16">
				<h2 class="text-4xl font-bold bg-gradient-to-r from-green-400 via-blue-400 to-purple-400 bg-clip-text text-transparent mb-4">
					Frontend Guides
				</h2>
				<p class="text-gray-300 text-lg">
					Integrate Ionyx with your favorite frontend frameworks
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
				<div class="bg-white/10 backdrop-blur-sm border border-blue-500/30 rounded-xl p-6 text-center hover:bg-blue-500/10 transition-all duration-300">
					<div class="w-16 h-16 bg-gradient-to-r from-blue-500 to-cyan-500 rounded-lg flex items-center justify-center mx-auto mb-4">
						<span class="text-3xl">⚛️</span>
					</div>
					<h3 class="text-lg font-semibold text-white mb-2">React</h3>
					<p class="text-gray-300 text-sm mb-4">
						Modern React with TypeScript
					</p>
					<a href="https://github.com/ionyx-apps/ionyx-cli/blob/main/docs/frontend/react.md" class="text-blue-400 hover:text-blue-300 transition-colors">
						View Guide →
					</a>
				</div>

				<div class="bg-white/10 backdrop-blur-sm border border-green-500/30 rounded-xl p-6 text-center hover:bg-green-500/10 transition-all duration-300">
					<div class="w-16 h-16 bg-gradient-to-r from-green-500 to-emerald-500 rounded-lg flex items-center justify-center mx-auto mb-4">
						<span class="text-3xl">🟩</span>
					</div>
					<h3 class="text-lg font-semibold text-white mb-2">Vue.js</h3>
					<p class="text-gray-300 text-sm mb-4">
						Progressive JavaScript framework
					</p>
					<a href="#" class="text-green-400 hover:text-green-300 transition-colors">
						Coming Soon →
					</a>
				</div>

				<div class="bg-white/10 backdrop-blur-sm border border-orange-500/30 rounded-xl p-6 text-center hover:bg-orange-500/10 transition-all duration-300">
					<div class="w-16 h-16 bg-gradient-to-r from-orange-500 to-red-500 rounded-lg flex items-center justify-center mx-auto mb-4">
						<span class="text-3xl">🔥</span>
					</div>
					<h3 class="text-lg font-semibold text-white mb-2">Svelte</h3>
					<p class="text-gray-300 text-sm mb-4">
						Cybernetically enhanced web apps
					</p>
					<a href="#" class="text-orange-400 hover:text-orange-300 transition-colors">
						Coming Soon →
					</a>
				</div>

				<div class="bg-white/10 backdrop-blur-sm border border-purple-500/30 rounded-xl p-6 text-center hover:bg-purple-500/10 transition-all duration-300">
					<div class="w-16 h-16 bg-gradient-to-r from-purple-500 to-pink-500 rounded-lg flex items-center justify-center mx-auto mb-4">
						<span class="text-3xl">📄</span>
					</div>
					<h3 class="text-lg font-semibold text-white mb-2">Vanilla JS</h3>
					<p class="text-gray-300 text-sm mb-4">
						Plain JavaScript and HTML
					</p>
					<a href="#" class="text-purple-400 hover:text-purple-300 transition-colors">
						Coming Soon →
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Configuration Section -->
	<section id="configuration" class="relative py-20 bg-gradient-to-br from-gray-900 via-pink-900/50 to-gray-900">
		<div class="absolute inset-0 overflow-hidden">
			<div class="absolute -top-20 -right-20 w-64 h-64 bg-gradient-to-br from-pink-500/10 to-transparent rounded-full blur-3xl animate-pulse"></div>
			<div class="absolute -bottom-20 -left-20 w-64 h-64 bg-gradient-to-br from-purple-500/10 to-transparent rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
		</div>
		
		<div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-16">
				<h2 class="text-4xl font-bold bg-gradient-to-r from-pink-400 via-purple-400 to-blue-400 bg-clip-text text-transparent mb-4">
					Configuration
				</h2>
				<p class="text-gray-300 text-lg">
					Configure your Ionyx applications with ionyx.config.toml
				</p>
			</div>

			<div class="bg-white/10 backdrop-blur-sm border border-pink-500/30 rounded-xl p-8">
				<h3 class="text-2xl font-semibold text-white mb-6">ionyx.config.toml</h3>
				<div class="bg-black/50 rounded-lg p-6 overflow-x-auto">
					<code class="text-green-400 text-sm">
[app]<br/>
name = "my-ionyx-app"<br/>
version = "1.0.0"<br/>
<br/>
[window]<br/>
title = "My App"<br/>
width = 1200<br/>
height = 800<br/>
resizable = true<br/>
<br/>
[permissions]<br/>
filesystem = ["./app-data", "./logs"]<br/>
network = true<br/>
os_info = true
					</code>
				</div>
			</div>

			<div class="text-center mt-12">
				<a href="https://github.com/ionyx-apps/ionyx-cli/blob/main/docs/configuration/config-file.md" class="group relative inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-white bg-gradient-to-r from-pink-600 to-purple-600 rounded-lg hover:from-pink-700 hover:to-purple-700 transform hover:-translate-y-1 transition-all duration-300 shadow-lg hover:shadow-pink-500/25">
					<span class="relative z-10">⚙️ View Configuration Guide</span>
