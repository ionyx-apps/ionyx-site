---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Ionyx Framework - Universal Desktop Framework">
	<div class="bg-gradient-to-br from-ionyx-50 to-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
			<div class="text-center">
				<h1 class="text-4xl md:text-6xl font-bold text-gray-900 mb-6">
					🚀 Ionyx Framework
				</h1>
				<p class="text-xl md:text-2xl text-gray-600 mb-8 max-w-3xl mx-auto">
					Universal desktop framework with Rust backend and agnostic frontend. Build high-performance, cross-platform desktop applications with ~3MB single binary distribution.
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					<a href="/docs" class="bg-ionyx-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-ionyx-700 transition-colors">
						Get Started
					</a>
					<a href="https://github.com/ionyx-apps/ionyx" class="border border-ionyx-600 text-ionyx-600 px-6 py-3 rounded-lg font-semibold hover:bg-ionyx-50 transition-colors">
						View on GitHub
					</a>
				</div>
			</div>
		</div>
	</div>

	<div class="py-20 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-16">
				<h2 class="text-3xl font-bold text-gray-900 mb-4">Why Choose Ionyx?</h2>
				<p class="text-lg text-gray-600 max-w-2xl mx-auto">
					Experience the perfect blend of Rust performance and modern web technologies
				</p>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				<div class="text-center">
					<div class="text-4xl mb-4">🦀</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-2">Rust Backend</h3>
					<p class="text-gray-600">
						Memory-safe, high-performance backend with TAO/WRY for native window management
					</p>
				</div>
				<div class="text-center">
					<div class="text-4xl mb-4">🎨</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-2">Frontend Agnostic</h3>
					<p class="text-gray-600">
						Support for React, Svelte, Leptos, or vanilla HTML/JS - use what you love
					</p>
				</div>
				<div class="text-center">
					<div class="text-4xl mb-4">📦</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-2">Single Binary</h3>
					<p class="text-gray-600">
						~3MB distribution with embedded frontend assets - no external dependencies
					</p>
				</div>
			</div>
		</div>
	</div>

	<div class="py-20 bg-gray-50">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-16">
				<h2 class="text-3xl font-bold text-gray-900 mb-4">Quick Start</h2>
				<p class="text-lg text-gray-600 max-w-2xl mx-auto">
					Get up and running in minutes with our simple CLI
				</p>
			</div>
			<div class="bg-gray-900 rounded-lg p-6 max-w-2xl mx-auto">
				<div class="text-sm text-gray-400 mb-2">bash</div>
				<pre class="text-green-400"><code># Install the CLI
npm install -g ionyx-framework

# Create a new project
npx create-ionyx-app

# Start development
cd your-app
npm run ionyx-dev</code></pre>
			</div>
		</div>
	</div>

	<div class="py-20 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-16">
				<h2 class="text-3xl font-bold text-gray-900 mb-4">Compare with Others</h2>
				<p class="text-lg text-gray-600 max-w-2xl mx-auto">
					See how Ionyx stacks up against popular desktop frameworks
				</p>
			</div>
			<div class="overflow-x-auto">
				<table class="min-w-full divide-y divide-gray-200">
					<thead class="bg-gray-50">
						<tr>
							<th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Feature</th>
							<th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Ionyx</th>
							<th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tauri</th>
							<th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Electron</th>
						</tr>
					</thead>
					<tbody class="bg-white divide-y divide-gray-200">
						<tr>
							<td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">Bundle Size</td>
							<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">~3MB</td>
							<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">~5-10MB</td>
							<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">~50-100MB</td>
						</tr>
						<tr>
							<td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">Performance</td>
							<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">Rust Native</td>
							<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">Rust Native</td>
							<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">Node.js</td>
						</tr>
						<tr>
							<td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">CLI</td>
							<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">✅ npmjs</td>
							<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">✅ npmjs</td>
							<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">❌ Manual</td>
						</tr>
						<tr>
							<td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">Security</td>
							<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">✅ Sandbox</td>
							<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">✅ Sandbox</td>
							<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">❌ Limited</td>
						</tr>
					</tbody>
				</table>
			</div>
		</div>
	</div>

	<div class="py-20 bg-ionyx-600">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<h2 class="text-3xl font-bold text-white mb-4">Ready to Build?</h2>
			<p class="text-xl text-ionyx-100 mb-8 max-w-2xl mx-auto">
				Join thousands of developers building amazing desktop applications with Ionyx Framework
			</p>
			<div class="flex flex-col sm:flex-row gap-4 justify-center">
				<a href="/docs" class="bg-white text-ionyx-600 px-6 py-3 rounded-lg font-semibold hover:bg-gray-50 transition-colors">
					Read Documentation
				</a>
				<a href="https://github.com/ionyx-apps/ionyx" class="border border-white text-white px-6 py-3 rounded-lg font-semibold hover:bg-ionyx-700 transition-colors">
					Star on GitHub
				</a>
			</div>
		</div>
	</div>
</Layout>
