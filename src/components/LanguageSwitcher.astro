---
const { currentLocale } = Astro.props;

const locales = [
  { code: 'en', name: 'English', flag: '🇺🇸' },
  { code: 'tr', name: 'Türkçe', flag: '🇹🇷' },
];
---

<div class="relative group">
  <button class="flex items-center space-x-2 px-3 py-2 text-sm text-gray-300 hover:text-white transition-colors">
    <span>{locales.find(l => l.code === currentLocale)?.flag}</span>
    <span>{locales.find(l => l.code === currentLocale)?.name}</span>
    <svg class="w-4 h-4 transform transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
    </svg>
  </button>
  
  <div class="absolute top-full right-0 mt-1 glass-dark rounded-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
    {locales.map(locale => (
      <a 
        href={locale.code === 'en' ? '/' : `/${locale.code}`}
        class={`flex items-center space-x-2 px-4 py-2 text-sm text-gray-300 hover:text-white hover:bg-white/5 transition-colors first:rounded-t-lg last:rounded-b-lg ${locale.code === currentLocale ? 'font-semibold' : ''}`}
      >
        <span>{locale.flag}</span>
        <span>{locale.name}</span>
      </a>
    ))}
  </div>
</div>
