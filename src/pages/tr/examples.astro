---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../utils/i18n';

const locale = 'tr';
const t = useTranslations(locale);
---

<BaseLayout title="Örnekler - Ionyx Framework" description="Ionyx ile geliştirilmiş örnek projeler">
	<section class="py-20 hero-gradient">
		<div class="max-w-4xl mx-auto px-6">
			<div class="max-w-4xl mx-auto text-center">
				<h1 class="text-5xl md:text-6xl font-bold text-white mb-6 tracking-tight">
					Örnekler
				</h1>
				<p class="text-xl text-gray-300 mb-8 leading-relaxed font-light">
					Ionyx ile neler inşa edebileceğinizi keşfedin
				</p>
			</div>
		</div>
	</section>

	<section class="py-20">
		<div class="max-w-4xl mx-auto px-6">
			<div class="max-w-6xl mx-auto">
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
					<div class="glass-dark rounded-xl p-6 border border-white/5 hover:border-purple-500/30 transition-all">
						<div class="w-12 h-12 bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue rounded-lg flex items-center justify-center mb-4 shadow-lg shadow-purple-500/20">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2H9a2 2 0 00-2 2z"></path>
							</svg>
						</div>
						<h3 class="text-xl font-semibold text-white mb-2">Yapılacaklar (Todo)</h3>
						<p class="text-gray-400 text-sm mb-4">React kullanılarak geliştirilmiş temel yönetim uygulaması.</p>
						<div class="flex items-center space-x-2 text-[10px] font-bold uppercase tracking-wider text-gray-500">
							<span class="px-2 py-1 bg-dark-tertiary rounded border border-white/5 text-purple-400">React</span>
							<span class="px-2 py-1 bg-dark-tertiary rounded border border-white/5 text-blue-400">TypeScript</span>
						</div>
						<div class="mt-4">
							<span class="text-yellow-500/80 text-xs font-medium flex items-center gap-1">
								<span class="w-1 h-1 rounded-full bg-yellow-500 animate-pulse"></span> Çok Yakında
							</span>
						</div>
					</div>

					<div class="glass-dark rounded-xl p-6 border border-white/5 hover:border-purple-500/30 transition-all">
						<div class="w-12 h-12 bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue rounded-lg flex items-center justify-center mb-4 shadow-lg shadow-purple-500/20">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
							</svg>
						</div>
						<h3 class="text-xl font-semibold text-white mb-2">Not Defteri</h3>
						<p class="text-gray-400 text-sm mb-4">Vue.js ile geliştirilmiş zengin metin editörü örneği.</p>
						<div class="flex items-center space-x-2 text-[10px] font-bold uppercase tracking-wider text-gray-500">
							<span class="px-2 py-1 bg-dark-tertiary rounded border border-white/5 text-emerald-400">Vue</span>
							<span class="px-2 py-1 bg-dark-tertiary rounded border border-white/5 text-blue-400">TypeScript</span>
						</div>
						<div class="mt-4">
							<span class="text-yellow-500/80 text-xs font-medium flex items-center gap-1">
								<span class="w-1 h-1 rounded-full bg-yellow-500 animate-pulse"></span> Çok Yakında
							</span>
						</div>
					</div>

					<div class="glass-dark rounded-xl p-6 border border-white/5 hover:border-purple-500/30 transition-all">
						<div class="w-12 h-12 bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue rounded-lg flex items-center justify-center mb-4 shadow-lg shadow-purple-500/20">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
							</svg>
						</div>
						<h3 class="text-xl font-semibold text-white mb-2">Hesap Makinesi</h3>
						<p class="text-gray-400 text-sm mb-4">Svelte ile inşa edilmiş hızlı ve hafif hesaplama aracı.</p>
						<div class="flex items-center space-x-2 text-[10px] font-bold uppercase tracking-wider text-gray-500">
							<span class="px-2 py-1 bg-dark-tertiary rounded border border-white/5 text-orange-400">Svelte</span>
							<span class="px-2 py-1 bg-dark-tertiary rounded border border-white/5 text-blue-400">TypeScript</span>
						</div>
						<div class="mt-4">
							<span class="text-yellow-500/80 text-xs font-medium flex items-center gap-1">
								<span class="w-1 h-1 rounded-full bg-yellow-500 animate-pulse"></span> Çok Yakında
							</span>
						</div>
					</div>

					<div class="glass-dark rounded-xl p-6 border border-white/5 hover:border-purple-500/30 transition-all">
						<div class="w-12 h-12 bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue rounded-lg flex items-center justify-center mb-4 shadow-lg shadow-purple-500/20 text-white">
							<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path>
							</svg>
						</div>
						<h3 class="text-xl font-semibold text-white mb-2">Dosya Yöneticisi</h3>
						<p class="text-gray-400 text-sm mb-4">Sade JavaScript ile yerel dosya sistemi gezgini.</p>
						<div class="flex items-center space-x-2 text-[10px] font-bold uppercase tracking-wider text-gray-500">
							<span class="px-2 py-1 bg-dark-tertiary rounded border border-white/5 text-yellow-400">Vanilla</span>
							<span class="px-2 py-1 bg-dark-tertiary rounded border border-white/5 text-blue-300">JS</span>
						</div>
						<div class="mt-4">
							<span class="text-yellow-500/80 text-xs font-medium flex items-center gap-1">
								<span class="w-1 h-1 rounded-full bg-yellow-500 animate-pulse"></span> Çok Yakında
							</span>
						</div>
					</div>

					<div class="glass-dark rounded-xl p-6 border border-white/5 hover:border-purple-500/30 transition-all">
						<div class="w-12 h-12 bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue rounded-lg flex items-center justify-center mb-4 shadow-lg shadow-purple-500/20 text-white">
							<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"></path>
							</svg>
						</div>
						<h3 class="text-xl font-semibold text-white mb-2">Hava Durumu</h3>
						<p class="text-gray-400 text-sm mb-4">API entegrasyonu ile canlı hava durumu paneli.</p>
						<div class="flex items-center space-x-2 text-[10px] font-bold uppercase tracking-wider text-gray-500">
							<span class="px-2 py-1 bg-dark-tertiary rounded border border-white/5 text-purple-400">React</span>
							<span class="px-2 py-1 bg-dark-tertiary rounded border border-white/5 text-red-400">API</span>
						</div>
						<div class="mt-4">
							<span class="text-yellow-500/80 text-xs font-medium flex items-center gap-1">
								<span class="w-1 h-1 rounded-full bg-yellow-500 animate-pulse"></span> Çok Yakında
							</span>
						</div>
					</div>

					<div class="glass-dark rounded-xl p-6 border border-white/5 hover:border-purple-500/30 transition-all">
						<div class="w-12 h-12 bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue rounded-lg flex items-center justify-center mb-4 shadow-lg shadow-purple-500/20 text-white">
							<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
							</svg>
						</div>
						<h3 class="text-xl font-semibold text-white mb-2">Mesajlaşma (Chat)</h3>
						<p class="text-gray-400 text-sm mb-4">WebSocket ile gerçek zamanlı mesajlaşma örneği.</p>
						<div class="flex items-center space-x-2 text-[10px] font-bold uppercase tracking-wider text-gray-500">
							<span class="px-2 py-1 bg-dark-tertiary rounded border border-white/5 text-blue-400">WebSocket</span>
							<span class="px-2 py-1 bg-dark-tertiary rounded border border-white/5 text-pink-400">Live</span>
						</div>
						<div class="mt-4">
							<span class="text-yellow-500/80 text-xs font-medium flex items-center gap-1">
								<span class="w-1 h-1 rounded-full bg-yellow-500 animate-pulse"></span> Çok Yakında
							</span>
						</div>
					</div>
				</div>

				<div class="mt-16 text-center">
					<div class="glass p-8 rounded-xl max-w-2xl mx-auto border border-white/10 shadow-2xl">
						<h2 class="text-3xl font-bold text-white mb-4 tracking-tight">
							Kendi Örneğinizi İnşa Edin
						</h2>
						<p class="text-gray-300 mb-6 font-light">
							Ionyx ile geliştirdiğiniz projeleri toplulukla paylaşın
						</p>
						<div class="flex flex-col sm:flex-row items-center justify-center space-y-4 sm:space-y-0 sm:space-x-4">
							<a href="/tr/docs" class="btn-primary w-full sm:w-auto">
								Başlarken
							</a>
							<a href="https://github.com/ionyx-apps/ionyx" class="btn-secondary w-full sm:w-auto">
								GitHub'da Katkıda Bulun
							</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>