---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Examples - Ionyx Framework">
	<section class="relative overflow-hidden hero-gradient">
		<div class="absolute inset-0 overflow-hidden">
			<div class="absolute -top-40 -right-40 w-96 h-96 bg-gradient-to-br from-ionyx-neon-purple/20 to-transparent rounded-full blur-3xl animate-pulse"></div>
			<div class="absolute -bottom-40 -left-40 w-96 h-96 bg-gradient-to-br from-ionyx-neon-blue/20 to-transparent rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
			<div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-gradient-to-br from-ionyx-neon-purple/10 to-transparent rounded-full blur-3xl animate-pulse" style="animation-delay: 2s;"></div>
		</div>
		
		<div class="relative z-10 max-w-7xl mx-auto px-6 py-24">
			<div class="text-center">
				<div class="inline-flex items-center px-4 py-2 glass px-4 py-2 rounded-full mb-8">
					<span class="text-sm text-gray-300">🎨 Real-World Applications</span>
				</div>
				
				<h1 class="text-5xl md:text-7xl lg:text-8xl font-bold text-white mb-6 leading-tight">
					<span class="bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue bg-clip-text text-transparent">Examples</span>
				</h1>
				
				<p class="text-xl md:text-2xl text-gray-300 mb-8 max-w-3xl mx-auto leading-relaxed">
					Explore real-world applications built with Ionyx Framework. From productivity tools to creative apps.
				</p>
				
				<div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
					<a href="#featured" class="group relative inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-white bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue rounded-lg hover:from-ionyx-neon-purple/80 hover:to-ionyx-neon-blue/80 transform hover:-translate-y-1 transition-all duration-300 shadow-lg hover:shadow-ionyx-neon-purple/25">
						<span class="relative z-10">Browse Examples</span>
						<div class="absolute inset-0 bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue rounded-lg blur opacity-75 group-hover:opacity-100 transition-opacity"></div>
					</a>
					<a href="https://github.com/ionyx-apps/ionyx-examples" class="group relative inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-white border border-gray-600 rounded-lg hover:bg-gray-800/50 transform hover:-translate-y-1 transition-all duration-300 backdrop-blur-sm">
						<span class="relative z-10">View on GitHub</span>
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Featured Examples -->
	<section id="featured" class="relative py-20">
		<div class="absolute inset-0 overflow-hidden">
			<div class="absolute -top-20 -right-20 w-64 h-64 bg-gradient-to-br from-ionyx-neon-purple/10 to-transparent rounded-full blur-3xl animate-pulse"></div>
			<div class="absolute -bottom-20 -left-20 w-64 h-64 bg-gradient-to-br from-ionyx-neon-blue/10 to-transparent rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
		</div>
		
		<div class="relative z-10 max-w-7xl mx-auto px-6">
			<div class="text-center mb-16">
				<h2 class="text-4xl font-bold text-white mb-4">
					Featured Examples
				</h2>
			</div>
			
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
				<div class="glass-dark p-8 rounded-xl hover:transform hover:scale-105 transition-all duration-300 text-center group">
					<div class="w-16 h-16 bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue rounded-lg mb-4 flex items-center justify-center mx-auto">
						<span class="text-white font-bold text-2xl">📝</span>
					</div>
					<h3 class="text-xl font-semibold text-white mb-2">Productivity Tool</h3>
					<p class="text-gray-400">Task manager with Ionyx backend</p>
				</div>
				
				<div class="glass-dark p-8 rounded-xl hover:transform hover:scale-105 transition-all duration-300 text-center group">
					<div class="w-16 h-16 bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue rounded-lg mb-4 flex items-center justify-center mx-auto">
						<span class="text-white font-bold text-2xl">🎨</span>
					</div>
					<h3 class="text-xl font-semibold text-white mb-2">Creative App</h3>
					<p class="text-gray-400">Design tool with custom UI</p>
				</div>
				
				<div class="glass-dark p-8 rounded-xl hover:transform hover:scale-105 transition-all duration-300 text-center group">
					<div class="w-16 h-16 bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue rounded-lg mb-4 flex items-center justify-center mx-auto">
						<span class="text-white font-bold text-2xl">⚙️</span>
					</div>
					<h3 class="text-xl font-semibold text-white mb-2">System Utility</h3>
					<p class="text-gray-400">System monitoring dashboard</p>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>
