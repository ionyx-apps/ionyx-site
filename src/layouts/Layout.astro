---
export interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Ionyx Framework - Universal desktop framework with Rust backend and agnostic frontend" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<style>
			@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
		</style>
	</head>
	<body>
		<style>
			@tailwind base;
			@tailwind components;
			@tailwind utilities;
		</style>
		<nav class="bg-white border-b border-gray-200">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="flex justify-between h-16">
					<div class="flex">
						<div class="flex-shrink-0 flex items-center">
							<a href="/" class="text-2xl font-bold text-ionyx-600">
								🚀 Ionyx Framework
							</a>
						</div>
						<div class="hidden sm:ml-6 sm:flex sm:space-x-8">
							<a href="/" class="border-ionyx-500 text-gray-900 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">
								Home
							</a>
							<a href="/docs" class="border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">
								Docs
							</a>
							<a href="/examples" class="border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">
								Examples
							</a>
							<a href="/blog" class="border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">
								Blog
							</a>
						</div>
					</div>
					<div class="flex items-center">
						<a href="https://github.com/ionyx-apps/ionyx" class="text-gray-500 hover:text-gray-700">
							<svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
								<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
							</svg>
						</a>
					</div>
				</div>
			</div>
		</nav>

		<main>
			<slot />
		</main>

		<footer class="bg-gray-50 border-t border-gray-200">
			<div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
				<div class="grid grid-cols-1 md:grid-cols-4 gap-8">
					<div class="col-span-1 md:col-span-2">
						<h3 class="text-lg font-semibold text-gray-900 mb-4">
							🚀 Ionyx Framework
						</h3>
						<p class="text-gray-600 mb-4">
							Universal desktop framework with Rust backend and agnostic frontend. Build high-performance, cross-platform desktop applications with ~3MB single binary distribution.
						</p>
						<div class="flex space-x-4">
							<a href="https://github.com/ionyx-apps/ionyx" class="text-gray-400 hover:text-gray-500">
								GitHub
							</a>
							<a href="https://www.npmjs.com/package/ionyx-framework" class="text-gray-400 hover:text-gray-500">
								NPM
							</a>
							<a href="https://discord.gg/ionyx" class="text-gray-400 hover:text-gray-500">
								Discord
							</a>
						</div>
					</div>
					<div>
						<h3 class="text-lg font-semibold text-gray-900 mb-4">Quick Links</h3>
						<ul class="space-y-2">
							<li>
								<a href="/docs" class="text-gray-600 hover:text-gray-900">Documentation</a>
							</li>
							<li>
								<a href="/examples" class="text-gray-600 hover:text-gray-900">Examples</a>
							</li>
							<li>
								<a href="/blog" class="text-gray-600 hover:text-gray-900">Blog</a>
							</li>
							<li>
								<a href="https://github.com/ionyx-apps/ionyx/releases" class="text-gray-600 hover:text-gray-900">Releases</a>
							</li>
						</ul>
					</div>
					<div>
						<h3 class="text-lg font-semibold text-gray-900 mb-4">Community</h3>
						<ul class="space-y-2">
							<li>
								<a href="https://github.com/ionyx-apps/ionyx/discussions" class="text-gray-600 hover:text-gray-900">Discussions</a>
							</li>
							<li>
								<a href="https://github.com/ionyx-apps/ionyx/issues" class="text-gray-600 hover:text-gray-900">Issues</a>
							</li>
							<li>
								<a href="https://github.com/ionyx-apps/ionyx/pulls" class="text-gray-600 hover:text-gray-900">Pull Requests</a>
							</li>
							<li>
								<a href="https://github.com/ionyx-apps/ionyx/blob/main/CONTRIBUTING.md" class="text-gray-600 hover:text-gray-900">Contributing</a>
							</li>
						</ul>
					</div>
				</div>
				<div class="mt-8 border-t border-gray-200 pt-8">
					<p class="text-center text-gray-500">
						&copy; 2026 Ionyx Framework. Built with ❤️ using Astro and Tailwind CSS.
					</p>
				</div>
			</div>
		</footer>
	</body>
</html>
