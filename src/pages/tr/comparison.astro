---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../utils/i18n';

const locale = 'tr';
const t = useTranslations(locale);
---

<BaseLayout title="Framework Karşılaştırması - Ionyx Framework" description="Ionyx'i diğer masaüstü uygulama framework'leri ile karşılaştırın">
	<section class="py-20 hero-gradient">
		<div class="container mx-auto px-6">
			<div class="max-w-4xl mx-auto text-center">
				<h1 class="text-5xl md:text-6xl font-bold text-white mb-6">
					Framework Karşılaştırması
				</h1>
				<p class="text-xl text-gray-300 leading-relaxed">
					Ionyx'in diğer masaüstü uygulama framework'leri ile karşılaştırması
				</p>
			</div>
		</div>
	</section>

	<section class="py-20">
		<div class="container mx-auto px-6">
			<div class="max-w-6xl mx-auto">
				<div class="glass-dark rounded-xl overflow-hidden">
					<table class="w-full">
						<thead>
							<tr class="border-b border-white/10">
								<th class="px-6 py-4 text-left text-gray-400 font-semibold">Özellik</th>
								<th class="px-6 py-4 text-center text-gray-400 font-semibold">Ionyx</th>
								<th class="px-6 py-4 text-center text-gray-400 font-semibold">Tauri™</th>
								<th class="px-6 py-4 text-center text-gray-400 font-semibold">Electron</th>
							</tr>
						</thead>
						<tbody class="divide-y divide-white/10">
							<tr class="hover:bg-white/5 transition-colors">
								<td class="px-6 py-4 text-gray-300 font-medium">Runtime Boyutu</td>
								<td class="px-6 py-4 text-center text-green-400 font-semibold">~1.66MB</td>
								<td class="px-6 py-4 text-center text-yellow-400 font-semibold">~10-50MB</td>
								<td class="px-6 py-4 text-center text-red-400 font-semibold">~100-200MB</td>
							</tr>
							<tr class="hover:bg-white/5 transition-colors">
								<td class="px-6 py-4 text-gray-300 font-medium">Backend</td>
								<td class="px-6 py-4 text-center text-gray-300">Rust</td>
								<td class="px-6 py-4 text-center text-gray-300">Rust</td>
								<td class="px-6 py-4 text-center text-gray-300">Node.js</td>
							</tr>
							<tr class="hover:bg-white/5 transition-colors">
								<td class="px-6 py-4 text-gray-300 font-medium">Frontend</td>
								<td class="px-6 py-4 text-center text-gray-300">Agnostik</td>
								<td class="px-6 py-4 text-center text-gray-300">Agnostik</td>
								<td class="px-6 py-4 text-center text-gray-300">Agnostik</td>
							</tr>
							<tr class="hover:bg-white/5 transition-colors">
								<td class="px-6 py-4 text-gray-300 font-medium">WebView</td>
								<td class="px-6 py-4 text-center text-gray-300">Sistem</td>
								<td class="px-6 py-4 text-center text-gray-300">Sistem</td>
								<td class="px-6 py-4 text-center text-gray-300">Bundled</td>
							</tr>
							<tr class="hover:bg-white/5 transition-colors">
								<td class="px-6 py-4 text-gray-300 font-medium">Memory Kullanımı</td>
								<td class="px-6 py-4 text-center text-green-400 font-semibold">10-20MB</td>
								<td class="px-6 py-4 text-center text-yellow-400 font-semibold">20-50MB</td>
								<td class="px-6 py-4 text-center text-red-400 font-semibold">100-200MB</td>
							</tr>
							<tr class="hover:bg-white/5 transition-colors">
								<td class="px-6 py-4 text-gray-300 font-medium">Başlangıç Süresi</td>
								<td class="px-6 py-4 text-center text-green-400 font-semibold">&lt;30ms</td>
								<td class="px-6 py-4 text-center text-yellow-400 font-semibold">~100ms</td>
								<td class="px-6 py-4 text-center text-red-400 font-semibold">~500ms</td>
							</tr>
							<tr class="hover:bg-white/5 transition-colors">
								<td class="px-6 py-4 text-gray-300 font-medium">Güvenlik</td>
								<td class="px-6 py-4 text-center text-green-400 font-semibold">✅ Sandbox</td>
								<td class="px-6 py-4 text-center text-green-400 font-semibold">✅ Sandbox</td>
								<td class="px-6 py-4 text-center text-red-400 font-semibold">❌ Sınırlı</td>
							</tr>
							<tr class="hover:bg-white/5 transition-colors">
								<td class="px-6 py-4 text-gray-300 font-medium">Geliştirme</td>
								<td class="px-6 py-4 text-center text-yellow-400 font-semibold">Erken</td>
								<td class="px-6 py-4 text-center text-green-400 font-semibold">Olgun</td>
								<td class="px-6 py-4 text-center text-green-400 font-semibold">Olgun</td>
							</tr>
						</tbody>
					</table>
				</div>

				<div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-8">
					<div class="glass-dark rounded-xl p-6">
						<h3 class="text-xl font-semibold text-white mb-4">Ionyx Avantajları</h3>
						<ul class="space-y-2 text-gray-300">
							<li class="flex items-start">
								<span class="text-green-400 mr-2">•</span>
								<span>Ultra-küçük binary boyutu</span>
							</li>
							<li class="flex items-start">
								<span class="text-green-400 mr-2">•</span>
								<span>Minimum kaynak kullanımı</span>
							</li>
							<li class="flex items-start">
								<span class="text-green-400 mr-2">•</span>
								<span>Hızlı başlangıç süresi</span>
							</li>
							<li class="flex items-start">
								<span class="text-green-400 mr-2">•</span>
								<span>Basit API tasarımı</span>
							</li>
						</ul>
					</div>

					<div class="glass-dark rounded-xl p-6">
						<h3 class="text-xl font-semibold text-white mb-4">Ionyx Ne Zaman Seçilmeli</h3>
						<ul class="space-y-2 text-gray-300">
							<li class="flex items-start">
								<span class="text-blue-400 mr-2">•</span>
								<span>Küçük yardımcı uygulamalar</span>
							</li>
							<li class="flex items-start">
								<span class="text-blue-400 mr-2">•</span>
								<span>Performans kritik uygulamalar</span>
							</li>
							<li class="flex items-start">
								<span class="text-blue-400 mr-2">•</span>
								<span>Kaynak kısıtlı ortamlar</span>
							</li>
							<li class="flex items-start">
								<span class="text-blue-400 mr-2">•</span>
								<span>Basit masaüstü araçları</span>
							</li>
						</ul>
					</div>

					<div class="glass-dark rounded-xl p-6">
						<h3 class="text-xl font-semibold text-white mb-4">Ödünleşmeler</h3>
						<ul class="space-y-2 text-gray-300">
							<li class="flex items-start">
								<span class="text-yellow-400 mr-2">•</span>
								<span>Sınırlı ekosistem</span>
							</li>
							<li class="flex items-start">
								<span class="text-yellow-400 mr-2">•</span>
								<span>Erken geliştirme aşaması</span>
							</li>
							<li class="flex items-start">
								<span class="text-yellow-400 mr-2">•</span>
								<span>Daha az yerleşik özellik</span>
							</li>
							<li class="flex items-start">
								<span class="text-yellow-400 mr-2">•</span>
								span>Küçük topluluk</span>
							</li>
						</ul>
					</div>
				</div>

				<!-- CTA Section -->
				<div class="mt-16 text-center">
					<div class="glass p-8 rounded-xl max-w-2xl mx-auto">
						<h2 class="text-3xl font-bold text-white mb-4">
							Doğru Framework'ü Seçin
						</h2>
						<p class="text-gray-300 mb-6">
							Her framework'ün kendi güçlü yönleri var. İhtiyaçlarınıza göre seçim yapın.
						</p>
						<div class="flex flex-col sm:flex-row items-center justify-center space-y-4 sm:space-y-0 sm:space-x-4">
							<a href="/docs" class="btn-primary w-full sm:w-auto">
								Ionyx'i Deneyin
							</a>
							<a href="/why-ionyx" class="btn-secondary w-full sm:w-auto">
								Daha Fazla Bilgi
							</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.ionyx-site\src\pages\tr\comparison.astro td {
		@apply border-b border-white/10;
	}
</style>
