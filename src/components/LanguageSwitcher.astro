---
const { currentLocale } = Astro.props;

// Get current path without locale prefix
const currentPath = Astro.url.pathname;
// Handle root path correctly
const pathWithoutLocale = currentPath === `/${currentLocale}` || currentPath === `/${currentLocale}/` 
  ? '/' 
  : currentPath.replace(new RegExp(`^/${currentLocale}`), '') || '/';

const locales = [
  { code: 'en', name: 'English', flag: '🇺🇸' },
  { code: 'tr', name: 'Türkçe', flag: '🇹🇷' },
];
---

<div class="relative">
  <input type="checkbox" id="lang-dropdown" class="hidden peer">
  <label for="lang-dropdown" class="flex items-center space-x-2 px-3 py-2 text-sm text-gray-300 hover:text-white transition-colors cursor-pointer">
    <span>{locales.find(l => l.code === currentLocale)?.flag}</span>
    <span>{locales.find(l => l.code === currentLocale)?.name}</span>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
    </svg>
  </label>
  
  <div class="absolute top-full right-0 mt-1 bg-gray-800/50 backdrop-blur-sm rounded-lg shadow-xl opacity-0 invisible transition-all duration-200 z-50 peer-checked:opacity-100 peer-checked:visible">
    {locales.map(locale => (
      <a 
        href={`/${locale.code}${pathWithoutLocale}`}
        class={`flex items-center space-x-2 px-4 py-2 text-sm text-gray-300 hover:text-white hover:bg-white/10 transition-colors first:rounded-t-lg last:rounded-b-lg ${locale.code === currentLocale ? 'font-semibold' : ''}`}
      >
        <span>{locale.flag}</span>
        <span>{locale.name}</span>
      </a>
    ))}
  </div>
</div>
