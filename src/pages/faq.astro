---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="SSS - Ionyx Framework">
	<section class="py-20 hero-gradient">
		<div class="container mx-auto px-6">
			<div class="max-w-4xl mx-auto">
				<div class="text-center mb-16">
					<h1 class="text-5xl md:text-6xl font-bold text-white mb-6">
						Sıkça Sorulan <span class="bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue bg-clip-text text-transparent">Sorular</span>
					</h1>
					<p class="text-xl text-gray-300 leading-relaxed">
						Ionyx hakkında merak edilenler
					</p>
				</div>

				<div class="space-y-6">
					<!-- Framework Comparison -->
					<div class="glass-dark rounded-xl overflow-hidden">
						<button class="w-full p-6 text-left flex items-center justify-between hover:bg-white/5 transition-colors" onclick="this.parentElement.classList.toggle('expanded')">
							<div class="flex items-center space-x-4">
								<div class="w-8 h-8 bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue rounded-lg flex items-center justify-center flex-shrink-0">
									<span class="text-white font-bold text-sm">F</span>
								</div>
								<h3 class="text-xl font-semibold text-white">Diğer framework'lerden farkı nedir?</h3>
							</div>
							<svg class="w-5 h-5 text-gray-400 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
							</svg>
						</button>
						<div class="px-6 pb-6 text-gray-300 leading-relaxed">
							<p class="mb-4">
								<strong class="text-white">Ionyx, minimalist desktop uygulama geliştirme için tasarlandı.</strong> 
								Electron, Tauri™ ve diğer framework'ler harika seçeneklerdir, ancak Ionyx farklı bir yaklaşım sunar:
							</p>
							<div class="bg-dark-tertiary rounded-lg p-4 border border-dark-border mb-4">
								<p class="text-sm text-gray-400 mb-2">🎯 <strong class="text-white">Electron:</strong> Full-featured, Node.js tabanlı</p>
								<p class="text-sm text-gray-400 mb-2">🎯 <strong class="text-white">Tauri™:</strong> Rust tabanlı, geniş ekosistem</p>
								<p class="text-sm text-gray-400">🎯 <strong class="text-white">Ionyx:</strong> Minimalist, ultra-küçük binary</p>
							</div>
							<p class="mb-4">
								Ionyx, sadece en temel özelliklere odaklanarak sub-3MB runtime hedefler. 
								Bu, onu küçük ve hızlı uygulamalar için ideal kılar.
							</p>
							<p class="text-xs text-gray-500">
								TAURI is a trademark of The Tauri Programme within the Commons Conservancy.
							</p>
						</div>
					</div>

					<!-- Binary Size -->
					<div class="glass-dark rounded-xl overflow-hidden">
						<button class="w-full p-6 text-left flex items-center justify-between hover:bg-white/5 transition-colors" onclick="this.parentElement.classList.toggle('expanded')">
							<div class="flex items-center space-x-4">
								<div class="w-8 h-8 bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue rounded-lg flex items-center justify-center flex-shrink-0">
									<span class="text-white font-bold text-sm">B</span>
								</div>
								<h3 class="text-xl font-semibold text-white">1.66MB binary boyutu nasıl mümkün?</h3>
							</div>
							<svg class="w-5 h-5 text-gray-400 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
							</svg>
						</button>
						<div class="px-6 pb-6 text-gray-300 leading-relaxed">
							<p class="mb-4">
								Minimalist mühendislik prensipleri sayesinde:
							</p>
							<ul class="space-y-2 mb-4">
								<li class="flex items-start">
									<span class="text-green-400 mr-2">•</span>
									<span>Hiçbir gereksiz dependency yok</span>
								</li>
								<li class="flex items-start">
									<span class="text-green-400 mr-2">•</span>
									<span>Sadece en temel WRY (0.54.2) ve TAO (0.34.5) kütüphaneleri</span>
								</li>
								<li class="flex items-start">
									<span class="text-green-400 mr-2">•</span>
									<span>Ekstra runtime taşımıyoruz (sistem WebView kullanıyoruz)</span>
								</li>
								<li class="flex items-start">
									<span class="text-green-400 mr-2">•</span>
									<span>Optimize edilmiş Rust kodu</span>
								</li>
							</ul>
							<div class="bg-dark-tertiary rounded-lg p-4 border border-dark-border">
								<p class="text-sm text-gray-400">
									<strong class="text-white">Breakdown:</strong> WRY (0.54.2) + TAO (0.34.5) + Ionyx Core (~0.8MB) = 1.66MB
								</p>
							</div>
						</div>
					</div>

					<!-- Frontend Framework -->
					<div class="glass-dark rounded-xl overflow-hidden">
						<button class="w-full p-6 text-left flex items-center justify-between hover:bg-white/5 transition-colors" onclick="this.parentElement.classList.toggle('expanded')">
							<div class="flex items-center space-x-4">
								<div class="w-8 h-8 bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue rounded-lg flex items-center justify-center flex-shrink-0">
									<span class="text-white font-bold text-sm">F</span>
								</div>
								<h3 class="text-xl font-semibold text-white">Hangi frontend framework'lerini destekliyor?</h3>
							</div>
							<svg class="w-5 h-5 text-gray-400 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
							</svg>
						</button>
						<div class="px-6 pb-6 text-gray-300 leading-relaxed">
							<p class="mb-4">
								<strong class="text-white">Agnostik yaklaşıyoruz:</strong> Herhangi bir frontend framework'ü ile çalışır.
							</p>
							<div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4">
								<div class="bg-dark-tertiary rounded-lg p-3 border border-dark-border text-center">
									<span class="text-sm text-gray-300">React</span>
								</div>
								<div class="bg-dark-tertiary rounded-lg p-3 border border-dark-border text-center">
									<span class="text-sm text-gray-300">Vue</span>
								</div>
								<div class="bg-dark-tertiary rounded-lg p-3 border border-dark-border text-center">
									<span class="text-sm text-gray-300">Svelte</span>
								</div>
								<div class="bg-dark-tertiary rounded-lg p-3 border border-dark-border text-center">
									<span class="text-sm text-gray-300">Angular</span>
								</div>
								<div class="bg-dark-tertiary rounded-lg p-3 border border-dark-border text-center">
									<span class="text-sm text-gray-300">Next.js</span>
								</div>
								<div class="bg-dark-tertiary rounded-lg p-3 border border-dark-border text-center">
									<span class="text-sm text-gray-300">Nuxt</span>
								</div>
								<div class="bg-dark-tertiary rounded-lg p-3 border border-dark-border text-center">
									<span class="text-sm text-gray-300">Vanilla JS</span>
								</div>
								<div class="bg-dark-tertiary rounded-lg p-3 border border-dark-border text-center">
									<span class="text-sm text-gray-300">Diğerleri</span>
								</div>
							</div>
							<p>
								WebView tabanlı olduğu için, tarayıcıda çalışan her şey Ionyx'te çalışır.
							</p>
						</div>
					</div>

					<!-- Performance -->
					<div class="glass-dark rounded-xl overflow-hidden">
						<button class="w-full p-6 text-left flex items-center justify-between hover:bg-white/5 transition-colors" onclick="this.parentElement.classList.toggle('expanded')">
							<div class="flex items-center space-x-4">
								<div class="w-8 h-8 bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue rounded-lg flex items-center justify-center flex-shrink-0">
									<span class="text-white font-bold text-sm">P</span>
								</div>
								<h3 class="text-xl font-semibold text-white">Performans avantajları neler?</h3>
							</div>
							<svg class="w-5 h-5 text-gray-400 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
							</svg>
						</button>
						<div class="px-6 pb-6 text-gray-300 leading-relaxed">
							<p class="mb-4">
								<strong class="text-white">Rakamlar konuşsun:</strong>
							</p>
							<div class="overflow-x-auto mb-4">
								<table class="w-full">
									<thead>
										<tr class="border-b border-white/10">
											<th class="text-left p-2 text-gray-400 text-sm">Metrik</th>
											<th class="text-center p-2 text-green-400 text-sm">Ionyx</th>
											<th class="text-center p-2 text-gray-400 text-sm">Electron</th>
										</tr>
									</thead>
									<tbody>
										<tr class="border-b border-white/5">
											<td class="p-2 text-gray-300 text-sm">Startup</td>
											<td class="p-2 text-center text-green-400 text-sm font-bold">&lt;30ms</td>
											<td class="p-2 text-center text-gray-400 text-sm">2-5s</td>
										</tr>
										<tr class="border-b border-white/5">
											<td class="p-2 text-gray-300 text-sm">Memory</td>
											<td class="p-2 text-center text-green-400 text-sm font-bold">10-20MB</td>
											<td class="p-2 text-center text-gray-400 text-sm">100-200MB</td>
										</tr>
										<tr>
											<td class="p-2 text-gray-300 text-sm">Binary Size</td>
											<td class="p-2 text-center text-green-400 text-sm font-bold">1.66MB</td>
											<td class="p-2 text-center text-gray-400 text-sm">120MB+</td>
										</tr>
									</tbody>
								</table>
							</div>
							<p>
								Bu fark, Rust'ın performansı ve minimalist yaklaşımımız sayesinde mümkün.
							</p>
						</div>
					</div>

					<!-- Production Ready -->
					<div class="glass-dark rounded-xl overflow-hidden">
						<button class="w-full p-6 text-left flex items-center justify-between hover:bg-white/5 transition-colors" onclick="this.parentElement.classList.toggle('expanded')">
							<div class="flex items-center space-x-4">
								<div class="w-8 h-8 bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue rounded-lg flex items-center justify-center flex-shrink-0">
									<span class="text-white font-bold text-sm">P</span>
								</div>
								<h3 class="text-xl font-semibold text-white">Production hazır mı?</h3>
							</div>
							<svg class="w-5 h-5 text-gray-400 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
							</svg>
						</button>
						<div class="px-6 pb-6 text-gray-300 leading-relaxed">
							<p class="mb-4">
								<strong class="text-white">Evet, production hazır.</strong> 
								Minimalist olmak demek, eksik olmak demek değil.
							</p>
							<ul class="space-y-2 mb-4">
								<li class="flex items-start">
									<span class="text-green-400 mr-2">✓</span>
									<span>Cross-platform destek (Windows, macOS, Linux)</span>
								</li>
								<li class="flex items-start">
									<span class="text-green-400 mr-2">✓</span>
									<span>Otomatik update sistemi</span>
								</li>
								<li class="flex items-start">
									<span class="text-green-400 mr-2">✓</span>
									<span>Code signing desteği</span>
								</li>
								<li class="flex items-start">
									<span class="text-green-400 mr-2">✓</span>
									<span>Native API erişimi</span>
								</li>
								<li class="flex items-start">
									<span class="text-green-400 mr-2">✓</span>
									<span>Güvenli sandbox ortamı</span>
								</li>
							</ul>
							<p>
								Şu anda production'da çalışan uygulamalar var ve framework stabil şekilde gelişiyor.
							</p>
						</div>
					</div>

					<!-- Learning Curve -->
					<div class="glass-dark rounded-xl overflow-hidden">
						<button class="w-full p-6 text-left flex items-center justify-between hover:bg-white/5 transition-colors" onclick="this.parentElement.classList.toggle('expanded')">
							<div class="flex items-center space-x-4">
								<div class="w-8 h-8 bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue rounded-lg flex items-center justify-center flex-shrink-0">
									<span class="text-white font-bold text-sm">L</span>
								</div>
								<h3 class="text-xl font-semibold text-white">Öğrenme eğrisi nasıl?</h3>
							</div>
							<svg class="w-5 h-5 text-gray-400 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
							</svg>
						</button>
						<div class="px-6 pb-6 text-gray-300 leading-relaxed">
							<p class="mb-4">
								<strong class="text-white">Çok düşük:</strong> Frontend bilgisi yeterli.
							</p>
							<div class="bg-dark-tertiary rounded-lg p-4 border border-dark-border mb-4">
								<p class="text-sm text-gray-400 mb-2">
									<strong class="text-white">Gerekenler:</strong>
								</p>
								<ul class="text-sm text-gray-400 space-y-1">
									<li>• HTML/CSS/JavaScript bilgisi</li>
									<li>• Seçtiğin frontend framework (isteğe bağlı)</li>
									<li>• Temel CLI komutları</li>
								</ul>
							</div>
							<p>
								Rust bilmenize gerek yok. Backend işlemleri için basit API'ler sunuyoruz. 
								5 dakikada ilk uygulamanızı çalıştırabilirsiniz.
							</p>
						</div>
					</div>
				</div>

				<!-- Still Have Questions -->
				<div class="mt-16 text-center">
					<div class="glass p-8 rounded-xl max-w-2xl mx-auto">
						<h2 class="text-2xl font-bold text-white mb-4">
							Hala sorularınız var mı?
						</h2>
						<p class="text-gray-300 mb-6">
							Dokümantasyonu inceleyin veya topluluğa katılın.
						</p>
						<div class="flex flex-col sm:flex-row items-center justify-center space-y-4 sm:space-y-0 sm:space-x-4">
							<a href="/docs" class="btn-primary w-full sm:w-auto">
								Dokümantasyon
							</a>
							<a href="https://github.com/ionyx-apps/ionyx/discussions" class="btn-secondary w-full sm:w-auto">
								GitHub Discussions
							</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<script>
		// FAQ accordion functionality
		document.querySelectorAll('.glass-dark').forEach(item => {
			const button = item.querySelector('button');
			const content = item.querySelector('.px-6.pb-6');
			
			if (button && content) {
				content.style.display = 'none';
				
				button.addEventListener('click', () => {
					const isExpanded = item.classList.contains('expanded');
					
					// Close all other items
					document.querySelectorAll('.glass-dark').forEach(otherItem => {
						if (otherItem !== item) {
							otherItem.classList.remove('expanded');
							otherItem.querySelector('.px-6.pb-6').style.display = 'none';
							otherItem.querySelector('svg').style.transform = 'rotate(0deg)';
						}
					});
					
					// Toggle current item
					if (isExpanded) {
						item.classList.remove('expanded');
						content.style.display = 'none';
						button.querySelector('svg').style.transform = 'rotate(0deg)';
					} else {
						item.classList.add('expanded');
						content.style.display = 'block';
						button.querySelector('svg').style.transform = 'rotate(180deg)';
					}
				});
			}
		});
	</script>
</BaseLayout>
