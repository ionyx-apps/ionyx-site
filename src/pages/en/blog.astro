---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const locale = 'en';
---

<BaseLayout title="Blog | Ionyx Framework">
  <div class="min-h-screen bg-[#0B0F1A] text-slate-300 selection:bg-purple-500/30">

    <div class="max-w-[1440px] mx-auto flex">

      <aside class="hidden lg:block w-72 fixed h-screen overflow-y-auto border-r border-slate-800/50 pt-24 pb-10 px-8 bg-[#0B0F1A]/50 backdrop-blur-xl">
        <nav class="space-y-8">
          <div>
            <h5 class="text-white font-bold mb-4 text-xs tracking-widest uppercase opacity-50">Latest Posts</h5>
            <ul class="space-y-3 border-l border-slate-800 ml-1">
              {posts.map((post) => (
                <li>
                  <a
                    href={`/en/blog/${post.id}`}
                    class="block pl-4 -ml-px border-l border-transparent hover:text-purple-400 transition-all text-sm"
                  >
                    {post.data.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </nav>
      </aside>

      <main class="flex-1 lg:ml-72 px-6 md:px-16 pt-24 pb-20">
        <div class="max-w-4xl mx-auto">

          <header class="mb-16">
            <h1 class="text-5xl font-black text-white mb-6 tracking-tighter">Blog</h1>
            <p class="text-xl text-slate-400 leading-relaxed font-light">
              Insights, tutorials, and updates from the Ionyx team.
            </p>
          </header>

          <div class="space-y-12">
            {posts.map((post) => (
              <article class="border-b border-slate-800/50 pb-12">
                <div class="flex items-start justify-between mb-4">
                  <div class="flex-1">
                    <h2 class="text-2xl font-bold text-white mb-2">
                      <a href={`/en/blog/${post.id}`} class="hover:text-purple-400 transition-colors">
                        {post.data.title}
                      </a>
                    </h2>
                    <p class="text-slate-400 text-sm mb-4">
                      {post.data.description}
                    </p>
                    <div class="flex items-center gap-4 text-xs text-slate-500">
                      <span>{post.data.author}</span>
                      <span>•</span>
                      <time datetime={post.data.pubDate.toISOString()}>
                        {post.data.pubDate.toLocaleDateString('en-US', {
                          year: 'numeric',
                          month: 'long',
                          day: 'numeric'
                        })}
                      </time>
                      {post.data.tags && (
                        <>
                          <span>•</span>
                          <div class="flex gap-2">
                            {post.data.tags.map((tag) => (
                              <span class="px-2 py-1 bg-slate-800/50 rounded text-xs">
                                #{tag}
                              </span>
                            ))}
                          </div>
                        </>
                      )}
                    </div>
                  </div>
                </div>
                <div class="mt-6">
                  <a
                    href={`/en/blog/${post.id}`}
                    class="inline-flex items-center gap-2 text-purple-400 hover:text-purple-300 transition-colors font-medium"
                  >
                    Read more
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                  </a>
                </div>
              </article>
            ))}
          </div>

          {posts.length === 0 && (
            <div class="text-center py-20">
              <div class="w-16 h-16 bg-slate-800/50 rounded-full flex items-center justify-center mx-auto mb-6">
                <svg class="w-8 h-8 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-white mb-2">No blog posts yet</h3>
              <p class="text-slate-400">Check back soon for updates and tutorials!</p>
            </div>
          )}

        </div>
      </main>

    </div>
  </div>
</BaseLayout>
