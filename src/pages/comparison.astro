---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Framework Comparison - Ionyx vs Others">
	<section class="relative overflow-hidden hero-gradient">
		<div class="container mx-auto px-6 py-24">
			<div class="text-center max-w-4xl mx-auto">
				<div class="inline-flex items-center space-x-2 glass px-4 py-2 rounded-full mb-6">
					<span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
					<span class="text-sm text-gray-300">Framework Comparison</span>
				</div>
				
				<h1 class="text-6xl md:text-7xl font-bold text-white mb-6">
					Ionyx vs <span class="bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue bg-clip-text text-transparent">Other Frameworks</span>
				</h1>
				
				<p class="text-xl text-gray-300 mb-8 max-w-2xl mx-auto leading-relaxed">
					Minimalist desktop application framework comparison. Ionyx focuses on ultra-small binaries and essential features.
				</p>
				
				<div class="flex flex-col sm:flex-row items-center justify-center space-y-4 sm:space-y-0 sm:space-x-4">
					<a href="/docs" class="btn-primary w-full sm:w-auto">
						Documentation
					</a>
					<a href="/faq" class="btn-secondary w-full sm:w-auto">
						FAQ
					</a>
				</div>
			</div>
		</div>
		
		<div class="absolute inset-0 bg-gradient-to-b from-transparent to-dark-primary/50 pointer-events-none"></div>
	</section>

	<section class="py-20">
		<div class="container mx-auto px-6">
			<div class="text-center mb-16">
				<h2 class="text-4xl font-bold text-white mb-4">
					Framework Karşılaştırması
				</h2>
				<p class="text-gray-400 text-lg">
					Minimalizm vs Full-Featured yaklaşımlar
				</p>
			</div>

			<div class="comparison-table max-w-6xl mx-auto overflow-x-auto">
				<table class="w-full">
					<thead>
						<tr class="border-b border-white/10">
							<th class="text-left p-6 text-gray-300 font-semibold">Özellik</th>
							<th class="text-center p-6">
								<div class="flex flex-col items-center">
									<span class="text-orange-400 font-semibold text-lg">Electron</span>
									<span class="text-sm text-gray-500">Full-Featured</span>
								</div>
							</th>
							<th class="text-center p-6">
								<div class="flex flex-col items-center">
									<span class="text-blue-400 font-semibold text-lg">Tauri™</span>
									<span class="text-sm text-gray-500">Rust-based</span>
								</div>
							</th>
							<th class="text-center p-6">
								<div class="flex flex-col items-center">
									<span class="bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue bg-clip-text text-transparent font-semibold text-lg">Ionyx</span>
									<span class="text-sm text-gray-500">Minimalist</span>
								</div>
							</th>
						</tr>
					</thead>
					<tbody>
						<tr class="border-b border-white/5 hover:bg-white/5 transition-colors">
							<td class="p-6 text-gray-300 font-medium">Ekosistem</td>
							<td class="p-6 text-center text-orange-400">Devasa</td>
							<td class="p-6 text-center text-blue-400">Geniş</td>
							<td class="p-6 text-center text-green-400">Odaklanmış</td>
						</tr>
						<tr class="border-b border-white/5 hover:bg-white/5 transition-colors">
							<td class="p-6 text-gray-300 font-medium">Binary Boyutu</td>
							<td class="p-6 text-center text-orange-400 font-mono">~50-100MB</td>
							<td class="p-6 text-center text-blue-400 font-mono">~15MB</td>
							<td class="p-6 text-center font-mono">
								<span class="bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue bg-clip-text text-transparent font-bold">1.66MB</span>
							</td>
						</tr>
						<tr class="border-b border-white/5 hover:bg-white/5 transition-colors">
							<td class="p-6 text-gray-300 font-medium">Özellikler</td>
							<td class="p-6 text-center text-orange-400">500+</td>
							<td class="p-6 text-center text-blue-400">300+</td>
							<td class="p-6 text-center text-green-400">Core only</td>
						</tr>
						<tr class="border-b border-white/5 hover:bg-white/5 transition-colors">
							<td class="p-6 text-gray-300 font-medium">Backend</td>
							<td class="p-6 text-center text-orange-400">Node.js</td>
							<td class="p-6 text-center text-blue-400">Rust</td>
							<td class="p-6 text-center text-green-400">Rust</td>
						</tr>
						<tr class="hover:bg-white/5 transition-colors">
							<td class="p-6 text-gray-300 font-medium">Kullanım Amacı</td>
							<td class="p-6 text-center text-orange-400">Enterprise apps</td>
							<td class="p-6 text-center text-blue-400">Desktop apps</td>
							<td class="p-6 text-center text-green-400">Minimal apps</td>
						</tr>
					</tbody>
				</table>
			</div>

			<div class="mt-12 text-center">
				<div class="glass-dark p-8 rounded-xl max-w-2xl mx-auto">
					<h3 class="text-xl font-semibold text-white mb-4">Sonuç</h3>
					<p class="text-gray-300">
						<strong class="text-white">Electron</strong> ve <strong class="text-white">Tauri™</strong> harika framework'ler ve farklı ihtiyaçlara hizmet ediyorlar. 
						<strong class="text-white">Ionyx</strong> ise farklı bir nişe odaklanıyor: mutlak minimalizm ve performans.
					</p>
					<p class="text-xs text-gray-500 mt-4">
						TAURI is a trademark of The Tauri Programme within the Commons Conservancy.
					</p>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>
