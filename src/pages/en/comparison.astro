---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../utils/i18n';

const locale = 'en';
const t = useTranslations(locale);
---

<BaseLayout title="Framework Comparison - Ionyx Framework" description="Compare Ionyx with other desktop application frameworks">
	<section class="py-20 hero-gradient">
		<div class="container mx-auto px-6">
			<div class="max-w-4xl mx-auto text-center">
				<h1 class="text-5xl md:text-6xl font-bold text-white mb-6">
					Framework Comparison
				</h1>
				<p class="text-xl text-gray-300 mb-8 leading-relaxed">
					How Ionyx compares to other desktop application frameworks
				</p>
			</div>
		</div>
	</section>

	<section class="py-20">
		<div class="container mx-auto px-6">
			<div class="max-w-6xl mx-auto">
				<div class="glass-dark rounded-xl overflow-hidden">
					<table class="w-full">
						<thead>
							<tr class="border-b border-white/10">
								<th class="px-6 py-4 text-left text-gray-400 font-semibold">Feature</th>
								<th class="px-6 py-4 text-center text-gray-400 font-semibold">Ionyx</th>
								<th class="px-6 py-4 text-center text-gray-400 font-semibold">Tauri™</th>
								<th class="px-6 py-4 text-center text-gray-400 font-semibold">Electron</th>
							</tr>
						</thead>
						<tbody class="divide-y divide-white/10">
							<tr class="hover:bg-white/5 transition-colors">
								<td class="px-6 py-4 text-gray-300 font-medium">Runtime Size</td>
								<td class="px-6 py-4 text-center text-green-400 font-semibold">~1.66MB</td>
								<td class="px-6 py-4 text-center text-yellow-400 font-semibold">~10-50MB</td>
								<td class="px-6 py-4 text-center text-red-400 font-semibold">~100-200MB</td>
							</tr>
							<tr class="hover:bg-white/5 transition-colors">
								<td class="px-6 py-4 text-gray-300 font-medium">Backend</td>
								<td class="px-6 py-4 text-center text-gray-300">Rust + WRY + TAO</td>
								<td class="px-6 py-4 text-center text-gray-300">Rust + WRY</td>
								<td class="px-6 py-4 text-center text-gray-300">Node.js</td>
							</tr>
							<tr class="hover:bg-white/5 transition-colors">
								<td class="px-6 py-4 text-gray-300 font-medium">Frontend</td>
								<td class="px-6 py-4 text-center text-gray-300">Agnostic</td>
								<td class="px-6 py-4 text-center text-gray-300">Agnostic</td>
								<td class="px-6 py-4 text-center text-gray-300">Agnostic</td>
							</tr>
							<tr class="hover:bg-white/5 transition-colors">
								<td class="px-6 py-4 text-gray-300 font-medium">WebView</td>
								<td class="px-6 py-4 text-center text-gray-300">System</td>
								<td class="px-6 py-4 text-center text-gray-300">System</td>
								<td class="px-6 py-4 text-center text-gray-300">Bundled</td>
							</tr>
							<tr class="hover:bg-white/5 transition-colors">
								<td class="px-6 py-4 text-gray-300 font-medium">Memory Usage</td>
								<td class="px-6 py-4 text-center text-green-400 font-semibold">10-20MB</td>
								<td class="px-6 py-4 text-center text-yellow-400 font-semibold">20-50MB</td>
								<td class="px-6 py-4 text-center text-red-400 font-semibold">100-200MB</td>
							</tr>
							<tr class="hover:bg-white/5 transition-colors">
								<td class="px-6 py-4 text-gray-300 font-medium">Startup Time</td>
								<td class="px-6 py-4 text-center text-green-400 font-semibold">&lt;30ms</td>
								<td class="px-6 py-4 text-center text-yellow-400 font-semibold">~100ms</td>
								<td class="px-6 py-4 text-center text-red-400 font-semibold">~500ms</td>
							</tr>
							<tr class="hover:bg-white/5 transition-colors">
								<td class="px-6 py-4 text-gray-300 font-medium">Security</td>
								<td class="px-6 py-4 text-center text-green-400 font-semibold">✅ Sandbox</td>
								<td class="px-6 py-4 text-center text-green-400 font-semibold">✅ Sandbox</td>
								<td class="px-6 py-4 text-center text-red-400 font-semibold">❌ Limited</td>
							</tr>
							<tr class="hover:bg-white/5 transition-colors">
								<td class="px-6 py-4 text-gray-300 font-medium">Development</td>
								<td class="px-6 py-4 text-center text-yellow-400 font-semibold">Early</td>
								<td class="px-6 py-4 text-center text-green-400 font-semibold">Mature</td>
								<td class="px-6 py-4 text-center text-green-400 font-semibold">Mature</td>
							</tr>
						</tbody>
					</table>
				</div>

				<div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-8">
					<div class="glass-dark rounded-xl p-6">
						<h3 class="text-xl font-semibold text-white mb-4">Ionyx Advantages</h3>
						<ul class="space-y-2 text-gray-300">
							<li class="flex items-start">
								<span class="text-green-400 mr-2">•</span>
								<span>Ultra-small binary size</span>
							</li>
							<li class="flex items-start">
								<span class="text-green-400 mr-2">•</span>
								<span>Minimal resource usage</span>
							</li>
							<li class="flex items-start">
								<span class="text-green-400 mr-2">•</span>
								<span>Fast startup time</span>
							</li>
							<li class="flex items-start">
								<span class="text-green-400 mr-2">•</span>
								<span>Simple API design</span>
							</li>
						</ul>
					</div>

					<div class="glass-dark rounded-xl p-6">
						<h3 class="text-xl font-semibold text-white mb-4">When to Choose Ionyx</h3>
						<ul class="space-y-2 text-gray-300">
							<li class="flex items-start">
								<span class="text-blue-400 mr-2">•</span>
								<span>Small utility applications</span>
							</li>
							<li class="flex items-start">
								<span class="text-blue-400 mr-2">•</span>
								<span>Performance-critical apps</span>
							</li>
							<li class="flex items-start">
								<span class="text-blue-400 mr-2">•</span>
								<span>Resource-constrained environments</span>
							</li>
							<li class="flex items-start">
								<span class="text-blue-400 mr-2">•</span>
								<span>Simple desktop tools</span>
							</li>
						</ul>
					</div>

					<div class="glass-dark rounded-xl p-6">
						<h3 class="text-xl font-semibold text-white mb-4">Trade-offs</h3>
						<ul class="space-y-2 text-gray-300">
							<li class="flex items-start">
								<span class="text-yellow-400 mr-2">•</span>
								<span>Limited ecosystem</span>
							</li>
							<li class="flex items-start">
								<span class="text-yellow-400 mr-2">•</span>
								<span>Early development stage</span>
							</li>
							<li class="flex items-start">
								<span class="text-yellow-400 mr-2">•</span>
								<span>Fewer built-in features</span>
							</li>
							<li class="flex items-start">
								<span class="text-yellow-400 mr-2">•</span>
								<span>Smaller community</span>
							</li>
						</ul>
					</div>
				</div>

				<!-- CTA Section -->
				<div class="mt-16 text-center">
					<div class="glass p-8 rounded-xl max-w-2xl mx-auto">
						<h2 class="text-3xl font-bold text-white mb-4">
							Choose the Right Framework
						</h2>
						<p class="text-gray-300 mb-6">
							Each framework has its strengths. Choose based on your needs.
						</p>
						<div class="flex flex-col sm:flex-row items-center justify-center space-y-4 sm:space-y-0 sm:space-x-4">
							<a href="/en/docs" class="btn-primary w-full sm:w-auto">
								Try Ionyx
							</a>
							<a href="/en/why-ionyx" class="btn-secondary w-full sm:w-auto">
								Learn More
							</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>
