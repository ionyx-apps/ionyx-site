---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Ionyx Framework - Universal Desktop Framework">
	<!-- Hero Section -->
	<section class="bg-gradient-to-br from-orange-50 via-white to-blue-50">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
			<div class="text-center">
				<h1 class="text-4xl md:text-6xl font-bold text-gray-900 mb-6">
					Ionyx Framework
				</h1>
				<p class="text-xl md:text-2xl text-gray-600 mb-8 max-w-3xl mx-auto">
					Create small, fast, secure, cross-platform applications
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
					<a href="/docs" class="bg-orange-600 text-white px-6 py-3 rounded-lg font-medium hover:bg-orange-700 transition-colors">
						Get started
					</a>
					<a href="https://github.com/ionyx-apps/ionyx" class="border border-gray-300 text-gray-700 px-6 py-3 rounded-lg font-medium hover:bg-gray-50 transition-colors">
						View on GitHub
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Create Project Section -->
	<section class="bg-white py-20">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-12">
				<h2 class="text-3xl font-bold text-gray-900 mb-4">Create a Project</h2>
				<p class="text-lg text-gray-600 mb-8">
					Choose your preferred package manager and get started in seconds
				</p>
			</div>
			
			<!-- Package Manager Tabs -->
			<div class="bg-gray-50 rounded-lg p-6 max-w-2xl mx-auto">
				<div class="flex flex-wrap gap-2 mb-6 justify-center">
					<button class="px-4 py-2 bg-white border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">
						Bash
					</button>
					<button class="px-4 py-2 bg-white border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">
						PowerShell
					</button>
					<button class="px-4 py-2 bg-white border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">
						Fish
					</button>
					<button class="px-4 py-2 bg-orange-600 text-white border border-orange-600 rounded-md text-sm font-medium">
						npm
					</button>
					<button class="px-4 py-2 bg-white border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">
						Yarn
					</button>
					<button class="px-4 py-2 bg-white border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">
						pnpm
					</button>
					<button class="px-4 py-2 bg-white border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">
						deno
					</button>
					<button class="px-4 py-2 bg-white border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">
						bun
					</button>
					<button class="px-4 py-2 bg-white border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">
						Cargo
					</button>
				</div>
				
				<!-- Command Display -->
				<div class="bg-gray-900 rounded-lg p-4">
					<pre class="text-green-400 font-mono text-sm"><code>npx create-ionyx-app@latest</code></pre>
				</div>
			</div>
		</div>
	</section>

	<!-- Features Section -->
	<section class="bg-gray-50 py-20">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-12">
				<!-- Frontend Independent -->
				<div class="flex items-start space-x-4">
					<div class="flex-shrink-0 w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center">
						<span class="text-orange-600 font-bold text-lg">🎨</span>
					</div>
					<div>
						<h3 class="text-xl font-semibold text-gray-900 mb-2">Frontend Independent</h3>
						<p class="text-gray-600 mb-4">
							Bring your existing web stack to Ionyx or start that new dream project. Ionyx supports any frontend framework so you don't need to change your stack.
						</p>
						<a href="/docs" class="text-orange-600 hover:text-orange-700 font-medium">
							Learn more →
						</a>
					</div>
				</div>

				<!-- Cross Platform -->
				<div class="flex items-start space-x-4">
					<div class="flex-shrink-0 w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center">
						<span class="text-blue-600 font-bold text-lg">🌐</span>
					</div>
					<div>
						<h3 class="text-xl font-semibold text-gray-900 mb-2">Cross Platform</h3>
						<p class="text-gray-600 mb-4">
							Build your app for Linux, macOS, Windows - all from a single codebase. Write your frontend in JavaScript, application logic in Rust.
						</p>
						<a href="/docs" class="text-blue-600 hover:text-blue-700 font-medium">
							Learn more →
						</a>
					</div>
				</div>

				<!-- Maximum Security -->
				<div class="flex items-start space-x-4">
					<div class="flex-shrink-0 w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center">
						<span class="text-green-600 font-bold text-lg">🔒</span>
					</div>
					<div>
						<h3 class="text-xl font-semibold text-gray-900 mb-2">Maximum Security</h3>
						<p class="text-gray-600 mb-4">
							Front-of-mind for the Ionyx Team that drives our highest priorities and biggest innovations.
						</p>
						<a href="/docs" class="text-green-600 hover:text-green-700 font-medium">
							Learn more →
						</a>
					</div>
				</div>

				<!-- Minimal Size -->
				<div class="flex items-start space-x-4">
					<div class="flex-shrink-0 w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center">
						<span class="text-purple-600 font-bold text-lg">📦</span>
					</div>
					<div>
						<h3 class="text-xl font-semibold text-gray-900 mb-2">Minimal Size</h3>
						<p class="text-gray-600 mb-4">
							By using the OS's native web renderer, the size of an Ionyx app can be as little as 3MB.
						</p>
						<a href="/docs" class="text-purple-600 hover:text-purple-700 font-medium">
							Learn more →
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Supported By Section -->
	<section class="bg-white py-20">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-12">
				<h2 class="text-2xl font-bold text-gray-900 mb-4">Support Ionyx</h2>
				<p class="text-lg text-gray-600 mb-8">
					Help us build the future of desktop development
				</p>
			</div>
			
			<div class="text-center">
				<div class="mb-8">
					<h3 class="text-lg font-semibold text-gray-700 mb-4">Become a Sponsor</h3>
					<p class="text-gray-600 mb-4">
						Your support helps us maintain and improve Ionyx Framework
					</p>
					<div class="flex justify-center space-x-4">
						<a href="https://opencollective.com/ionyx" class="bg-orange-600 text-white px-6 py-3 rounded-lg font-medium hover:bg-orange-700 transition-colors">
							Support on Open Collective
						</a>
						<a href="https://github.com/sponsors/ionyx-apps" class="border border-gray-300 text-gray-700 px-6 py-3 rounded-lg font-medium hover:bg-gray-50 transition-colors">
							Sponsor on GitHub
						</a>
					</div>
				</div>
				
				<div>
					<h3 class="text-lg font-semibold text-gray-700 mb-4">Community Contributors</h3>
					<p class="text-gray-600 mb-4">
						Built with ❤️ by the open source community
					</p>
					<div class="flex justify-center space-x-4">
						<a href="https://github.com/ionyx-apps/ionyx/graphs/contributors" class="text-gray-600 hover:text-gray-900">
							<span class="text-sm">View Contributors</span>
						</a>
						<a href="https://github.com/ionyx-apps/ionyx/discussions" class="text-gray-600 hover:text-gray-900">
							<span class="text-sm">Join Discussion</span>
						</a>
						<a href="https://github.com/ionyx-apps/ionyx/issues" class="text-gray-600 hover:text-gray-900">
							<span class="text-sm">Report Issues</span>
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Footer -->
	<footer class="bg-gray-50 border-t border-gray-200 py-8">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center">
				<p class="text-gray-600 mb-4">
					Website powered by
				</p>
				<div class="flex justify-center space-x-6">
					<a href="https://opencollective.com/ionyx" class="text-gray-600 hover:text-gray-900">
						Support on Open Collective
					</a>
					<a href="https://github.com/sponsors/ionyx-apps" class="text-gray-600 hover:text-gray-900">
						Sponsor on GitHub
					</a>
				</div>
				<p class="text-gray-500 text-sm mt-4">
					2026 Ionyx Contributors. CC-BY / MIT
				</p>
			</div>
		</div>
	</footer>
</Layout>
