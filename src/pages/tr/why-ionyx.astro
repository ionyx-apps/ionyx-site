---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../utils/i18n';

const locale = 'tr';
const t = useTranslations(locale);
---

<BaseLayout title="Neden Ionyx?" description="Ultra-minimalist masaüstü uygulama çatısı">
	<section class="py-20 hero-gradient">
		<div class="max-w-4xl mx-auto px-6">
			<div class="max-w-4xl mx-auto text-center">
				<h1 class="text-5xl md:text-6xl font-bold text-white mb-6">
					Neden Ionyx?
				</h1>
				<p class="text-xl text-gray-300 mb-8 leading-relaxed">
					Minimalist yaklaşım ile modern masaüstü uygulamaları. Rust backend ve frontend-bağımsız yapı.
				</p>
			</div>
		</div>
	</section>

	<section class="py-20">
		<div class="max-w-4xl mx-auto px-6">
			<div class="max-w-4xl mx-auto space-y-12">
				<!-- Agnostic Frontend -->
				<div class="glass-dark p-8 rounded-xl">
					<div class="flex items-start space-x-4">
						<div class="w-12 h-12 bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue rounded-lg flex items-center justify-center flex-shrink-0">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
							</svg>
						</div>
						<div>
							<h2 class="text-2xl font-bold text-white mb-4">Frontend-Bağımsız</h2>
							<p class="text-gray-300 mb-4 leading-relaxed">
								İstediğiniz frontend framework'ünü kullanın. React, Vue, Svelte veya vanilla JavaScript - Ionyx hepsiyle çalışır.
							</p>
							<div class="grid grid-cols-2 md:grid-cols-4 gap-4">
								<div class="bg-dark-tertiary rounded-lg p-3 text-center">
									<span class="text-blue-400 font-semibold">React</span>
								</div>
								<div class="bg-dark-tertiary rounded-lg p-3 text-center">
									<span class="text-green-400 font-semibold">Vue</span>
								</div>
								<div class="bg-dark-tertiary rounded-lg p-3 text-center">
									<span class="text-orange-400 font-semibold">Svelte</span>
								</div>
								<div class="bg-dark-tertiary rounded-lg p-3 text-center">
									<span class="text-yellow-400 font-semibold">Vanilla</span>
								</div>
							</div>
						</div>
					</div>
				</div>

				<!-- Rust Backend -->
				<div class="glass-dark p-8 rounded-xl">
					<div class="flex items-start space-x-4">
						<div class="w-12 h-12 bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue rounded-lg flex items-center justify-center flex-shrink-0">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
							</svg>
						</div>
						<div>
							<h2 class="text-2xl font-bold text-white mb-4">Güçlü Rust Backend</h2>
							<p class="text-gray-300 mb-4 leading-relaxed">
								Rust'un güvenliği ve performansından yararlanın. Bellek güvenliği, konkurensi ve hızlı execution.
							</p>
							<div class="grid grid-cols-1 md:grid-cols-3 gap-4">
								<div class="bg-dark-tertiary rounded-lg p-3 text-center">
									<span class="text-red-400 font-semibold">🔒 Güvenli</span>
								</div>
								<div class="bg-dark-tertiary rounded-lg p-3 text-center">
									<span class="text-green-400 font-semibold">⚡ Hızlı</span>
								</div>
								<div class="bg-dark-tertiary rounded-lg p-3 text-center">
									<span class="text-blue-400 font-semibold">🚀 Modern</span>
								</div>
							</div>
						</div>
					</div>
				</div>

				<!-- Minimal Size -->
				<div class="glass-dark p-8 rounded-xl">
					<div class="flex items-start space-x-4">
						<div class="w-12 h-12 bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue rounded-lg flex items-center justify-center flex-shrink-0">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
							</svg>
						</div>
						<div>
							<h2 class="text-2xl font-bold text-white mb-4">Minimal Boyut</h2>
							<p class="text-gray-300 mb-4 leading-relaxed">
								Ultra-küçük ikili boyutu ile uygulamalarınızı dağıtın. Sadece ~1.66MB ile hızlı indirme ve kurulum.
							</p>
							<div class="bg-dark-tertiary rounded-lg p-4 border border-dark-border">
								<p class="text-sm text-gray-400 mb-2">📦 <strong class="text-white">Ionyx:</strong> ~1.66MB</p>
								<p class="text-sm text-gray-400 mb-2">📦 <strong class="text-white">Tauri™:</strong> ~10-50MB</p>
								<p class="text-sm text-gray-400">📦 <strong class="text-white">Electron:</strong> ~100-200MB</p>
							</div>
						</div>
					</div>
				</div>

				<!-- Simple API -->
				<div class="glass-dark p-8 rounded-xl">
					<div class="flex items-start space-x-4">
						<div class="w-12 h-12 bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue rounded-lg flex items-center justify-center flex-shrink-0">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
							</svg>
						</div>
						<div>
							<h2 class="text-2xl font-bold text-white mb-4">Basit API</h2>
							<p class="text-gray-300 mb-4 leading-relaxed">
								Öğrenmesi kolay, temiz ve modern API. Hızlı geliştirme için tasarlandı.
							</p>
							<div class="bg-dark-tertiary rounded-lg p-4 font-mono text-sm">
								<p class="text-green-400 mb-2">// Basit API çağrısı</p>
								<p class="text-gray-300 mb-2">const result = await ionyx.fs.readFile('path.txt');</p>
								<p class="text-gray-300">console.log(result);</p>
							</div>
						</div>
					</div>
				</div>

				<!-- CTA Section -->
				<div class="mt-16 text-center">
					<div class="glass p-8 rounded-xl max-w-2xl mx-auto">
						<h2 class="text-3xl font-bold text-white mb-4">
							Hemen Başlayın
						</h2>
						<p class="text-gray-300 mb-6">
							Ionyx'in gücünü keşfedin ve modern masaüstü uygulamaları oluşturun
						</p>
						<div class="flex flex-col sm:flex-row items-center justify-center space-y-4 sm:space-y-0 sm:space-x-4">
							<a href="/tr/docs" class="btn-primary w-full sm:w-auto">
								Başlarken
							</a>
							<a href="/tr/examples" class="btn-secondary w-full sm:w-auto">
								Örnekleri İnceleyin
							</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>
