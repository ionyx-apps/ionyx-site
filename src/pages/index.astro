---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Ionyx Framework - Universal Desktop Framework">
	<div class="hero-gradient min-h-screen flex items-center relative overflow-hidden">
		<!-- Background decoration -->
		<div class="absolute inset-0 overflow-hidden">
			<div class="absolute -top-40 -right-40 w-80 h-80 bg-gradient-to-br from-ionyx-500/20 to-transparent rounded-full blur-3xl floating"></div>
			<div class="absolute -bottom-40 -left-40 w-80 h-80 bg-gradient-to-tr from-ionyx-600/20 to-transparent rounded-full blur-3xl floating" style="animation-delay: 2s;"></div>
		</div>
		
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
			<div class="text-center slide-in">
				<div class="inline-flex items-center px-3 py-1 rounded-full bg-ionyx-100 text-ionyx-700 text-sm font-medium mb-6">
					🚀 Quantum leap in desktop development
				</div>
				
				<h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-gray-900 mb-6 leading-tight">
					<span class="text-gradient">Ionyx Framework</span>
				</h1>
				
				<p class="text-xl md:text-2xl text-gray-600 mb-8 max-w-3xl mx-auto leading-relaxed">
					Universal desktop framework with Rust backend and agnostic frontend. Build high-performance, cross-platform desktop applications with ~3MB single binary distribution.
				</p>
				
				<div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
					<a href="/docs" class="gradient-bg text-white px-8 py-4 rounded-lg font-semibold hover:shadow-lg transform hover:-translate-y-1 transition-all duration-200 glow">
						Get Started
					</a>
					<a href="https://github.com/ionyx-apps/ionyx" class="border border-gray-300 text-gray-700 px-8 py-4 rounded-lg font-semibold hover:bg-gray-50 hover:border-gray-400 transform hover:-translate-y-1 transition-all duration-200">
						View on GitHub
					</a>
				</div>
				
				<!-- Quick install command -->
				<div class="bg-gray-900 rounded-lg p-6 max-w-2xl mx-auto shadow-2xl">
					<div class="flex items-center justify-between mb-4">
						<span class="text-sm text-gray-400 font-medium">Quick Install</span>
						<button class="text-gray-400 hover:text-white transition-colors" onclick="navigator.clipboard.writeText('npx create-ionyx-app')">
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
							</svg>
						</button>
					</div>
					<pre class="text-green-400 font-mono text-sm"><code>npx create-ionyx-app</code></pre>
				</div>
			</div>
		</div>
	</div>

	<!-- Features Section -->
	<div class="py-24 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-16 slide-in">
				<h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Why Choose Ionyx?</h2>
				<p class="text-lg text-gray-600 max-w-2xl mx-auto">
					Experience the perfect blend of Rust performance and modern web technologies
				</p>
			</div>
			
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				<div class="card-hover bg-white p-8 rounded-xl border border-gray-200 text-center slide-in">
					<div class="text-5xl mb-6 floating">🦀</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-3">Rust Backend</h3>
					<p class="text-gray-600 leading-relaxed">
						Memory-safe, high-performance backend with TAO/WRY for native window management and system integration
					</p>
				</div>
				
				<div class="card-hover bg-white p-8 rounded-xl border border-gray-200 text-center slide-in" style="animation-delay: 0.1s;">
					<div class="text-5xl mb-6 floating" style="animation-delay: 1s;">🎨</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-3">Frontend Agnostic</h3>
					<p class="text-gray-600 leading-relaxed">
						Support for React, Svelte, Leptos, or vanilla HTML/JS - use what you love with zero configuration
					</p>
				</div>
				
				<div class="card-hover bg-white p-8 rounded-xl border border-gray-200 text-center slide-in" style="animation-delay: 0.2s;">
					<div class="text-5xl mb-6 floating" style="animation-delay: 2s;">📦</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-3">Single Binary</h3>
					<p class="text-gray-600 leading-relaxed">
						~3MB distribution with embedded frontend assets - no external dependencies required
					</p>
				</div>
			</div>
		</div>
	</div>

	<!-- Architecture Section -->
	<div class="py-24 bg-gray-50">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
				<div class="slide-in">
					<h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
						Modern Architecture
					</h2>
					<p class="text-lg text-gray-600 mb-8">
						Built with modern technologies and best practices in mind. Ionyx Framework combines the power of Rust with the flexibility of web technologies.
					</p>
					
					<div class="space-y-6">
						<div class="flex items-start space-x-4">
							<div class="flex-shrink-0 w-8 h-8 bg-ionyx-100 rounded-lg flex items-center justify-center">
								<span class="text-ionyx-600 font-semibold">1</span>
							</div>
							<div>
								<h3 class="font-semibold text-gray-900 mb-1">Rust Backend</h3>
								<p class="text-gray-600">High-performance, memory-safe backend with native system access</p>
							</div>
						</div>
						
						<div class="flex items-start space-x-4">
							<div class="flex-shrink-0 w-8 h-8 bg-ionyx-100 rounded-lg flex items-center justify-center">
								<span class="text-ionyx-600 font-semibold">2</span>
							</div>
							<div>
								<h3 class="font-semibold text-gray-900 mb-1">IPC Bridge</h3>
								<p class="text-gray-600">Secure communication between frontend and backend</p>
							</div>
						</div>
						
						<div class="flex items-start space-x-4">
							<div class="flex-shrink-0 w-8 h-8 bg-ionyx-100 rounded-lg flex items-center justify-center">
								<span class="text-ionyx-600 font-semibold">3</span>
							</div>
							<div>
								<h3 class="font-semibold text-gray-900 mb-1">Frontend</h3>
								<p class="text-gray-600">Your choice of framework with embedded assets</p>
							</div>
						</div>
					</div>
				</div>
				
				<div class="slide-in" style="animation-delay: 0.3s;">
					<div class="bg-white p-8 rounded-xl border border-gray-200 shadow-lg">
						<div class="text-center mb-6">
							<div class="inline-flex items-center px-3 py-1 rounded-full bg-ionyx-100 text-ionyx-700 text-sm font-medium mb-4">
								Architecture Overview
							</div>
						</div>
						
						<div class="space-y-4">
							<div class="bg-gray-50 p-4 rounded-lg border-l-4 border-ionyx-600">
								<div class="font-semibold text-gray-900">Frontend Layer</div>
								<div class="text-sm text-gray-600">React, Svelte, Leptos, or Vanilla</div>
							</div>
							
							<div class="bg-gray-50 p-4 rounded-lg border-l-4 border-ionyx-500">
								<div class="font-semibold text-gray-900">IPC Bridge</div>
								<div class="text-sm text-gray-600">Secure JavaScript-Rust communication</div>
							</div>
							
							<div class="bg-gray-50 p-4 rounded-lg border-l-4 border-ionyx-400">
								<div class="font-semibold text-gray-900">Rust Backend</div>
								<div class="text-sm text-gray-600">TAO/WRY window management</div>
							</div>
							
							<div class="bg-gray-50 p-4 rounded-lg border-l-4 border-ionyx-300">
								<div class="font-semibold text-gray-900">System Integration</div>
								<div class="text-sm text-gray-600">Native OS APIs and file system</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Comparison Section -->
	<div class="py-24 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-16 slide-in">
				<h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Compare with Others</h2>
				<p class="text-lg text-gray-600 max-w-2xl mx-auto">
					See how Ionyx stacks up against popular desktop frameworks
				</p>
			</div>
			
			<div class="overflow-x-auto">
				<div class="bg-white rounded-xl border border-gray-200 shadow-lg overflow-hidden">
					<table class="min-w-full divide-y divide-gray-200">
						<thead class="bg-gray-50">
							<tr>
								<th class="px-6 py-4 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Feature</th>
								<th class="px-6 py-4 text-left text-xs font-medium text-gray-500 uppercase tracking-wider text-center">
									<div class="inline-flex items-center px-3 py-1 rounded-full bg-ionyx-100 text-ionyx-700 text-sm font-medium">
										Ionyx
									</div>
								</th>
								<th class="px-6 py-4 text-left text-xs font-medium text-gray-500 uppercase tracking-wider text-center">Tauri</th>
								<th class="px-6 py-4 text-left text-xs font-medium text-gray-500 uppercase tracking-wider text-center">Electron</th>
							</tr>
						</thead>
						<tbody class="bg-white divide-y divide-gray-200">
							<tr class="hover:bg-gray-50 transition-colors">
								<td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">Bundle Size</td>
								<td class="px-6 py-4 whitespace-nowrap text-sm text-center">
									<span class="inline-flex items-center px-2 py-1 rounded-full bg-green-100 text-green-800 text-xs font-medium">~3MB</span>
								</td>
								<td class="px-6 py-4 whitespace-nowrap text-sm text-center text-gray-500">~5-10MB</td>
								<td class="px-6 py-4 whitespace-nowrap text-sm text-center text-gray-500">~50-100MB</td>
							</tr>
							<tr class="hover:bg-gray-50 transition-colors">
								<td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">Performance</td>
								<td class="px-6 py-4 whitespace-nowrap text-sm text-center">
									<span class="inline-flex items-center px-2 py-1 rounded-full bg-green-100 text-green-800 text-xs font-medium">Rust Native</span>
								</td>
								<td class="px-6 py-4 whitespace-nowrap text-sm text-center text-gray-500">Rust Native</td>
								<td class="px-6 py-4 whitespace-nowrap text-sm text-center text-gray-500">Node.js</td>
							</tr>
							<tr class="hover:bg-gray-50 transition-colors">
								<td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">CLI</td>
								<td class="px-6 py-4 whitespace-nowrap text-sm text-center">
									<span class="inline-flex items-center px-2 py-1 rounded-full bg-green-100 text-green-800 text-xs font-medium">✅ npmjs</span>
								</td>
								<td class="px-6 py-4 whitespace-nowrap text-sm text-center text-gray-500">✅ npmjs</td>
								<td class="px-6 py-4 whitespace-nowrap text-sm text-center text-gray-500">❌ Manual</td>
							</tr>
							<tr class="hover:bg-gray-50 transition-colors">
								<td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">Security</td>
								<td class="px-6 py-4 whitespace-nowrap text-sm text-center">
									<span class="inline-flex items-center px-2 py-1 rounded-full bg-green-100 text-green-800 text-xs font-medium">✅ Sandbox</span>
								</td>
								<td class="px-6 py-4 whitespace-nowrap text-sm text-center text-gray-500">✅ Sandbox</td>
								<td class="px-6 py-4 whitespace-nowrap text-sm text-center text-gray-500">❌ Limited</td>
							</tr>
						</tbody>
					</table>
				</div>
			</div>
		</div>
	</div>

	<!-- CTA Section -->
	<div class="gradient-bg py-24">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<div class="slide-in">
				<h2 class="text-3xl md:text-4xl font-bold text-white mb-6">Ready to Build?</h2>
				<p class="text-xl text-ionyx-100 mb-8 max-w-2xl mx-auto">
					Join thousands of developers building amazing desktop applications with Ionyx Framework
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					<a href="/docs" class="bg-white text-ionyx-600 px-8 py-4 rounded-lg font-semibold hover:bg-gray-50 transform hover:-translate-y-1 transition-all duration-200">
						Read Documentation
					</a>
					<a href="https://github.com/ionyx-apps/ionyx" class="border border-white text-white px-8 py-4 rounded-lg font-semibold hover:bg-white/10 transform hover:-translate-y-1 transition-all duration-200">
						Star on GitHub
					</a>
				</div>
			</div>
		</div>
	</div>
</Layout>
