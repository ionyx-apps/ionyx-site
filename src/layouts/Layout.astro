---
export interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Ionyx Framework - Universal desktop framework with Rust backend and agnostic frontend" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<style>
			:root {
				--ionyx-primary: #3b82f6;
				--ionyx-secondary: #8b5cf6;
				--ionyx-accent: #ec4899;
				--ionyx-bg: #ffffff;
				--ionyx-surface: #f8fafc;
				--ionyx-text: #1e293b;
				--ionyx-text-secondary: #64748b;
				--ionyx-border: #e2e8f0;
				--ionyx-success: #10b981;
				--ionyx-warning: #f59e0b;
				--ionyx-error: #ef4444;
			}

			[data-theme="dark"] {
				--ionyx-primary: #38bdf8;
				--ionyx-secondary: #a78bfa;
				--ionyx-accent: #f472b6;
				--ionyx-bg: #0f172a;
				--ionyx-surface: #1e293b;
				--ionyx-text: #f1f5f9;
				--ionyx-text-secondary: #94a3b8;
				--ionyx-border: #334155;
				--ionyx-success: #34d399;
				--ionyx-warning: #fbbf24;
				--ionyx-error: #f87171;
			}

			* {
				box-sizing: border-box;
			}

			body {
				font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
				margin: 0;
				padding: 0;
				background: var(--ionyx-bg);
				color: var(--ionyx-text);
				line-height: 1.6;
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
			}

			.text-gradient {
				background: linear-gradient(135deg, var(--ionyx-primary), var(--ionyx-secondary), var(--ionyx-accent));
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
			}

			.nav-blur {
				backdrop-filter: blur(10px);
				-webkit-backdrop-filter: blur(10px);
			}

			.hero-gradient {
				background: linear-gradient(135deg, var(--ionyx-primary), var(--ionyx-secondary));
			}

			[data-theme="dark"] .hero-gradient {
				background: linear-gradient(135deg, var(--ionyx-primary), var(--ionyx-secondary));
			}

			.glow {
				box-shadow: 0 0 20px rgba(59, 130, 246, 0.5);
			}

			.floating {
				animation: floating 3s ease-in-out infinite;
			}

			@keyframes floating {
				0%, 100% { transform: translateY(0px); }
				50% { transform: translateY(-10px); }
			}

			.pulse {
				animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
			}

			@keyframes pulse {
				0%, 100% { opacity: 1; }
				50% { opacity: 0.5; }
			}

			.slide-in {
				animation: slideIn 0.5s ease-out;
			}

			@keyframes slideIn {
				from {
					opacity: 0;
					transform: translateY(20px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}

			.bg-grid-pattern {
				background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.1) 1px, transparent 0);
				background-size: 40px 40px;
			}
		</style>
	</head>
	<body>
		<style>
			@tailwind base;
			@tailwind components;
			@tailwind utilities;
		</style>
		
		<nav class="fixed top-0 left-0 right-0 z-50 border-b border-gray-800/50 backdrop-blur-md bg-gray-900/80">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="flex justify-between h-16">
					<div class="flex">
						<div class="flex-shrink-0 flex items-center">
							<a href="/" class="text-2xl font-bold bg-gradient-to-r from-blue-400 via-purple-400 to-pink-400 bg-clip-text text-transparent">
								🚀 Ionyx Framework
							</a>
						</div>
						<div class="hidden sm:ml-6 sm:flex sm:space-x-8">
							<a href="/" class="text-white inline-flex items-center px-1 pt-1 border-b-2 border-purple-500 text-sm font-medium">
								Home
							</a>
							<a href="/docs" class="text-gray-300 hover:text-white inline-flex items-center px-1 pt-1 border-b-2 border-transparent hover:border-gray-600 text-sm font-medium transition-colors">
								Docs
							</a>
							<a href="/examples" class="text-gray-300 hover:text-white inline-flex items-center px-1 pt-1 border-b-2 border-transparent hover:border-gray-600 text-sm font-medium transition-colors">
								Examples
							</a>
							<a href="/blog" class="text-gray-300 hover:text-white inline-flex items-center px-1 pt-1 border-b-2 border-transparent hover:border-gray-600 text-sm font-medium transition-colors">
								Blog
							</a>
						</div>
					</div>
					<div class="flex items-center space-x-4">
						<button id="theme-toggle" class="text-gray-400 hover:text-white transition-colors p-2 rounded-lg hover:bg-gray-800/50 border border-gray-700/50">
							<svg class="h-5 w-5 hidden dark:block" fill="currentColor" viewBox="0 0 20 20">
								<path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 012 0zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 012 0zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 100 2h1z"/>
							</svg>
							<svg class="h-5 w-5 block dark:hidden" fill="currentColor" viewBox="0 0 20 20">
								<path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/>
							</svg>
						</button>
						<a href="https://github.com/ionyx-apps/ionyx" class="text-gray-400 hover:text-white transition-colors p-2 rounded-lg hover:bg-gray-800/50 border border-gray-700/50">
							<svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
								<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
							</svg>
						</a>
						<a href="https://www.npmjs.com/package/ionyx-framework" class="group relative inline-flex items-center justify-center px-4 py-2 text-sm font-semibold text-white bg-gradient-to-r from-purple-600 to-blue-600 rounded-lg hover:from-purple-700 hover:to-blue-700 transform hover:-translate-y-0.5 transition-all duration-300 shadow-lg hover:shadow-purple-500/25">
							<span class="relative z-10">npx create-ionyx-app</span>
							<div class="absolute inset-0 bg-gradient-to-r from-purple-600 to-blue-600 rounded-lg blur opacity-75 group-hover:opacity-100 transition-opacity"></div>
						</a>
					</div>
				</div>
			</div>
		</nav>

		<main>
			<slot />
		</main>

		<footer class="bg-black/50 backdrop-blur-sm border-t border-gray-800/50 py-8">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="text-center">
					<p class="text-gray-400 mb-4">
						Website powered by
					</p>
					<div class="flex justify-center space-x-6">
						<a href="https://opencollective.com/ionyx" class="text-gray-400 hover:text-gray-300">
							Support on Open Collective
						</a>
						<a href="https://github.com/sponsors/ionyx-apps" class="text-gray-400 hover:text-gray-300">
							Sponsor on GitHub
						</a>
					</div>
					<p class="text-gray-500 text-sm mt-4">
						&copy; 2026 Ionyx Contributors. CC-BY / MIT
					</p>
				</div>
			</div>
		</footer>
		
		<script>
			// Theme toggle functionality
			const themeToggle = document.getElementById('theme-toggle');
			const html = document.documentElement;
			
			// Set initial theme
			const currentTheme = localStorage.getItem('theme') || 'light';
			html.setAttribute('data-theme', currentTheme);
			
			// Toggle theme
			themeToggle.addEventListener('click', () => {
				const currentTheme = html.getAttribute('data-theme');
				const newTheme = currentTheme === 'light' ? 'dark' : 'light';
				html.setAttribute('data-theme', newTheme);
				localStorage.setItem('theme', newTheme);
			});
			
			// Detect system preference
			if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches && !localStorage.getItem('theme')) {
				html.setAttribute('data-theme', 'dark');
			}
			
			// Listen for system theme changes
			window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', e => {
				if (!localStorage.getItem('theme')) {
					html.setAttribute('data-theme', e.matches ? 'dark' : 'light');
				}
			});
		</script>
	</body>
</html>
