---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../utils/i18n';

const locale = 'en';
const t = useTranslations(locale);
---

<BaseLayout title="Examples - Ionyx Framework" description="Example projects built with Ionyx">
	<section class="py-20 hero-gradient">
		<div class="container mx-auto px-6">
			<div class="max-w-4xl mx-auto text-center">
				<h1 class="text-5xl md:text-6xl font-bold text-white mb-6">
					Examples
				</h1>
				<p class="text-xl text-gray-300 mb-8 leading-relaxed">
					See what you can build with Ionyx
				</p>
			</div>
		</div>
	</section>

	<section class="py-20">
		<div class="container mx-auto px-6">
			<div class="max-w-6xl mx-auto">
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
					<!-- Todo App -->
					<div class="glass-dark rounded-xl p-6">
						<div class="w-12 h-12 bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue rounded-lg flex items-center justify-center mb-4">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2H9a2 2 0 00-2 2z"></path>
							</svg>
						</div>
						<h3 class="text-xl font-semibold text-white mb-2">Todo App</h3>
						<p class="text-gray-300 mb-4">Simple todo application with React</p>
						<div class="flex items-center space-x-2 text-sm text-gray-400">
							<span class="px-2 py-1 bg-dark-tertiary rounded">React</span>
							<span class="px-2 py-1 bg-dark-tertiary rounded">TypeScript</span>
						</div>
						<div class="mt-4">
							<span class="text-yellow-400 text-sm">Coming Soon</span>
						</div>
					</div>

					<!-- Notes App -->
					<div class="glass-dark rounded-xl p-6">
						<div class="w-12 h-12 bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue rounded-lg flex items-center justify-center mb-4">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
							</svg>
						</div>
						<h3 class="text-xl font-semibold text-white mb-2">Notes App</h3>
						<p class="text-gray-300 mb-4">Rich text editor with Vue.js</p>
						<div class="flex items-center space-x-2 text-sm text-gray-400">
							<span class="px-2 py-1 bg-dark-tertiary rounded">Vue</span>
							<span class="px-2 py-1 bg-dark-tertiary rounded">TypeScript</span>
						</div>
						<div class="mt-4">
							<span class="text-yellow-400 text-sm">Coming Soon</span>
						</div>
					</div>

					<!-- Calculator -->
					<div class="glass-dark rounded-xl p-6">
						<div class="w-12 h-12 bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue rounded-lg flex items-center justify-center mb-4">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
							</svg>
						</div>
						<h3 class="text-xl font-semibold text-white mb-2">Calculator</h3>
						<p class="text-gray-300 mb-4">Simple calculator with Svelte</p>
						<div class="flex items-center space-x-2 text-sm text-gray-400">
							<span class="px-2 py-1 bg-dark-tertiary rounded">Svelte</span>
							<span class="px-2 py-1 bg-dark-tertiary rounded">TypeScript</span>
						</div>
						<div class="mt-4">
							<span class="text-yellow-400 text-sm">Coming Soon</span>
						</div>
					</div>

					<!-- File Manager -->
					<div class="glass-dark rounded-xl p-6">
						<div class="w-12 h-12 bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue rounded-lg flex items-center justify-center mb-4">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path>
							</svg>
						</div>
						<h3 class="text-xl font-semibold text-white mb-2">File Manager</h3>
						<p class="text-gray-300 mb-4">Native file explorer with vanilla JS</p>
						<div class="flex items-center space-x-2 text-sm text-gray-400">
							<span class="px-2 py-1 bg-dark-tertiary rounded">Vanilla</span>
							<span class="px-2 py-1 bg-dark-tertiary rounded">JavaScript</span>
						</div>
						<div class="mt-4">
							<span class="text-yellow-400 text-sm">Coming Soon</span>
						</div>
					</div>

					<!-- Weather App -->
					<div class="glass-dark rounded-xl p-6">
						<div class="w-12 h-12 bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue rounded-lg flex items-center justify-center mb-4">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"></path>
							</svg>
						</div>
						<h3 class="text-xl font-semibold text-white mb-2">Weather App</h3>
						<p class="text-gray-300 mb-4">Weather dashboard with API integration</p>
						<div class="flex items-center space-x-2 text-sm text-gray-400">
							<span class="px-2 py-1 bg-dark-tertiary rounded">React</span>
							<span class="px-2 py-1 bg-dark-tertiary rounded">API</span>
						</div>
						<div class="mt-4">
							<span class="text-yellow-400 text-sm">Coming Soon</span>
						</div>
					</div>

					<!-- Chat App -->
					<div class="glass-dark rounded-xl p-6">
						<div class="w-12 h-12 bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue rounded-lg flex items-center justify-center mb-4">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
							</svg>
						</div>
						<h3 class="text-xl font-semibold text-white mb-2">Chat App</h3>
						<p class="text-gray-300 mb-4">Real-time chat with WebSocket</p>
						<div class="flex items-center space-x-2 text-sm text-gray-400">
							<span class="px-2 py-1 bg-dark-tertiary rounded">WebSocket</span>
							<span class="px-2 py-1 bg-dark-tertiary rounded">Real-time</span>
						</div>
						<div class="mt-4">
							<span class="text-yellow-400 text-sm">Coming Soon</span>
						</div>
					</div>
				</div>

				<!-- CTA Section -->
				<div class="mt-16 text-center">
					<div class="glass p-8 rounded-xl max-w-2xl mx-auto">
						<h2 class="text-3xl font-bold text-white mb-4">
							Build Your Own Example
						</h2>
						<p class="text-gray-300 mb-6">
							Share your Ionyx projects with the community
						</p>
						<div class="flex flex-col sm:flex-row items-center justify-center space-y-4 sm:space-y-0 sm:space-x-4">
							<a href="/en/docs" class="btn-primary w-full sm:w-auto">
								Get Started
							</a>
							<a href="https://github.com/ionyx-apps/ionyx" class="btn-secondary w-full sm:w-auto">
								Contribute on GitHub
							</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>
