---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../utils/i18n';

const locale = 'en';
const t = useTranslations(locale);
---

<BaseLayout title="Why Ionyx?" description="Ultra-minimalist desktop application framework">
	<section class="py-20 hero-gradient">
		<div class="container mx-auto px-6">
			<div class="max-w-4xl mx-auto text-center">
				<h1 class="text-5xl md:text-6xl font-bold text-white mb-6">
					Why Ionyx?
				</h1>
				<p class="text-xl text-gray-300 mb-8 leading-relaxed">
					Modern desktop applications with a minimalist approach. Rust backend and frontend-agnostic structure.
				</p>
			</div>
		</div>
	</section>

	<section class="py-20">
		<div class="container mx-auto px-6">
			<div class="max-w-4xl mx-auto space-y-12">
				<!-- Agnostic Frontend -->
				<div class="glass-dark p-8 rounded-xl">
					<div class="flex items-start space-x-4">
						<div class="w-12 h-12 bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue rounded-lg flex items-center justify-center flex-shrink-0">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
							</svg>
						</div>
						<div>
							<h2 class="text-2xl font-bold text-white mb-4">Frontend-Agnostic</h2>
							<p class="text-gray-300 mb-4 leading-relaxed">
								Use any frontend framework you want. React, Vue, Svelte, or vanilla JavaScript - Ionyx works with all of them.
							</p>
							<div class="grid grid-cols-2 md:grid-cols-4 gap-4">
								<div class="bg-dark-tertiary rounded-lg p-3 text-center">
									<span class="text-blue-400 font-semibold">React</span>
								</div>
								<div class="bg-dark-tertiary rounded-lg p-3 text-center">
									<span class="text-green-400 font-semibold">Vue</span>
								</div>
								<div class="bg-dark-tertiary rounded-lg p-3 text-center">
									<span class="text-orange-400 font-semibold">Svelte</span>
								</div>
								<div class="bg-dark-tertiary rounded-lg p-3 text-center">
									<span class="text-yellow-400 font-semibold">Vanilla</span>
								</div>
							</div>
						</div>
					</div>
				</div>

				<!-- The 1.66MB CLI -->
				<div class="glass-dark p-8 rounded-xl">
					<div class="flex items-start space-x-4">
						<div class="w-12 h-12 bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue rounded-lg flex items-center justify-center flex-shrink-0">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
							</svg>
						</div>
						<div>
							<h2 class="text-2xl font-bold text-white mb-4">The 1.66MB CLI</h2>
							<p class="text-gray-300 mb-4 leading-relaxed">
								Our 1.66MB CLI is an incredible engineering achievement. Built on WRY 0.54.2 and TAO 0.34.5, 
								this minimalist structure carries no unnecessary code. Just pure performance and speed.
							</p>
							<div class="grid grid-cols-1 md:grid-cols-3 gap-4">
								<div class="bg-dark-tertiary rounded-lg p-4 border border-dark-border">
									<p class="text-sm text-gray-400 mb-2">WRY</p>
									<p class="text-xs text-gray-500">0.54.2 - WebView wrapper</p>
								</div>
								<div class="bg-dark-tertiary rounded-lg p-4 border border-dark-border">
									<p class="text-sm text-gray-400 mb-2">TAO</p>
									<p class="text-xs text-gray-500">0.34.5 - Window management</p>
								</div>
								<div class="bg-dark-tertiary rounded-lg p-4 border border-dark-border">
									<p class="text-sm text-gray-400 mb-2">Ionyx Core</p>
									<p class="text-xs text-gray-500">~0.8MB - Framework logic</p>
								</div>
							</div>
						</div>
					</div>
				</div>

				<!-- No Extra Runtime -->
				<div class="glass-dark p-8 rounded-xl">
					<div class="flex items-start space-x-4">
						<div class="w-12 h-12 bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue rounded-lg flex items-center justify-center flex-shrink-0">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
							</svg>
						</div>
						<div>
							<h2 class="text-2xl font-bold text-white mb-4">No Extra Runtime</h2>
							<p class="text-gray-300 mb-4 leading-relaxed">
								No extra runtimes like Node.js or Electron. Use system WebView for native performance and minimum resource usage.
							</p>
							<div class="bg-dark-tertiary rounded-lg p-4 border border-dark-border">
								<p class="text-sm text-gray-400 mb-2">Single Binary Distribution:</p>
								<ul class="text-xs text-gray-500 space-y-1">
									<li>• Windows: .exe</li>
									<li>• macOS: .app</li>
									<li>• Linux: AppImage</li>
								</ul>
							</div>
						</div>
					</div>
				</div>

				<!-- Rust Backend -->
				<div class="glass-dark p-8 rounded-xl">
					<div class="flex items-start space-x-4">
						<div class="w-12 h-12 bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue rounded-lg flex items-center justify-center flex-shrink-0">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
							</svg>
						</div>
						<div>
							<h2 class="text-2xl font-bold text-white mb-4">Rust Backend</h2>
							<p class="text-gray-300 mb-4 leading-relaxed">
								Secure and performant Rust backend. Memory safety, thread safety, and zero-cost abstractions.
							</p>
							<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
								<div class="bg-dark-tertiary rounded-lg p-4 border border-dark-border">
									<p class="text-sm text-gray-400 mb-2">Security:</p>
									<p class="text-xs text-gray-500">Memory safe, type safe</p>
								</div>
								<div class="bg-dark-tertiary rounded-lg p-4 border border-dark-border">
									<p class="text-sm text-gray-400 mb-2">Performance:</p>
									<p class="text-xs text-gray-500">C++ level speed</p>
								</div>
							</div>
						</div>
					</div>
				</div>

				<!-- Cross Platform -->
				<div class="glass-dark p-8 rounded-xl">
					<div class="flex items-start space-x-4">
						<div class="w-12 h-12 bg-gradient-to-r from-ionyx-neon-purple to-ionyx-neon-blue rounded-lg flex items-center justify-center flex-shrink-0">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
							</svg>
						</div>
						<div>
							<h2 class="text-2xl font-bold text-white mb-4">Cross Platform</h2>
							<p class="text-gray-300 mb-4 leading-relaxed">
								Native applications for all platforms from a single codebase. Windows, macOS, and Linux support.
							</p>
							<div class="flex flex-wrap gap-2">
								<span class="px-3 py-1 bg-dark-tertiary rounded-full text-xs text-gray-400">Windows</span>
								<span class="px-3 py-1 bg-dark-tertiary rounded-full text-xs text-gray-400">macOS</span>
								<span class="px-3 py-1 bg-dark-tertiary rounded-full text-xs text-gray-400">Linux</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>
