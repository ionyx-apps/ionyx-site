---
import BaseLayout from '../../layouts/BaseLayout.astro';

const createCode = `ionyx create my-app --template react`;
const devCode = `cd my-app\nionyx dev`;
const configCode = `// ionyx.config.json\n{\n  "window": {\n    "title": "My Ionyx App",\n    "width": 800,\n    "height": 600\n  }\n}`;
---

<BaseLayout title="Documentation | Ionyx Framework">
  <div class="min-h-screen bg-[#0B0F1A] text-slate-300 selection:bg-purple-500/30">
    
    <div class="max-w-[1440px] mx-auto flex">
      
      <aside class="hidden lg:block w-72 fixed h-screen overflow-y-auto border-r border-slate-800/50 pt-24 pb-10 px-8 bg-[#0B0F1A]/50 backdrop-blur-xl">
        <nav class="space-y-8">
          <div>
            <h5 class="text-white font-bold mb-4 text-xs tracking-widest uppercase opacity-50">Introduction</h5>
            <ul class="space-y-3 border-l border-slate-800 ml-1">
              <li><a href="/en/docs#why-ionyx" class="block pl-4 -ml-px border-l border-transparent hover:text-purple-400 transition-all">Why Ionyx?</a></li>
              <li><a href="/en/docs#comparison" class="block pl-4 -ml-px border-l border-transparent hover:text-purple-400 transition-all text-sm">Tauri & Electron Comparison</a></li>
            </ul>
          </div>
          <div>
            <h5 class="text-white font-bold mb-4 text-xs tracking-widest uppercase opacity-50">Core Guide</h5>
            <ul class="space-y-3 border-l border-slate-800 ml-1">
              <li><a href="#installation" class="block pl-4 -ml-px border-l border-transparent hover:text-purple-400 transition-all">Installation</a></li>
              <li><a href="#quick-start" class="block pl-4 -ml-px border-l border-transparent hover:text-purple-400 transition-all">Quick Start</a></li>
            </ul>
          </div>
          <div>
            <h5 class="text-white font-bold mb-4 text-xs tracking-widest uppercase opacity-50">Features (New)</h5>
            <ul class="space-y-3 border-l border-slate-800 ml-1">
              <li><a href="/en/docs/guides/fusion" class="block pl-4 -ml-px border-l border-transparent hover:text-purple-400 transition-all text-sm">Native Fusion</a></li>
              <li><a href="/en/docs/guides/webgpu" class="block pl-4 -ml-px border-l border-transparent hover:text-purple-400 transition-all text-sm">WebGPU</a></li>
              <li><a href="/en/docs/guides/cli-tooling" class="block pl-4 -ml-px border-l border-transparent hover:text-purple-400 transition-all text-sm">CLI & Bundling</a></li>
            </ul>
          </div>
          <div>
            <h5 class="text-white font-bold mb-4 text-xs tracking-widest uppercase opacity-50">Blog</h5>
            <ul class="space-y-3 border-l border-slate-800 ml-1">
              <li><a href="/en/blog" class="block pl-4 -ml-px border-l border-transparent hover:text-purple-400 transition-all">CLI Introduction</a></li>
            </ul>
          </div>
        </nav>
      </aside>

      <main class="flex-1 lg:ml-72 lg:mr-64 px-6 md:px-16 pt-24 pb-20">
        <article class="max-w-4xl mx-auto">
          
          <header class="mb-16">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-xs font-bold mb-6">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
              </span>
              <span>v1.0.0 Stable Release</span>
            </div>
            <h1 id="documentation-title" class="text-5xl font-black text-white mb-6 tracking-tighter">Documentation</h1>
            <p class="text-xl text-slate-400 leading-relaxed font-light">
                Ionyx is a minimalist, high-performance toolkit for building desktop apps with Rust. It provides the smallest binary size in the ecosystem.
            </p>
          </header>

          <section id="whats-new" class="scroll-mt-32 mb-24 p-8 rounded-3xl bg-gradient-to-br from-purple-500/10 via-transparent to-emerald-500/10 border border-white/5 relative overflow-hidden">
            <div class="absolute top-0 right-0 p-4 opacity-10">
                <svg class="w-24 h-24" fill="currentColor" viewBox="0 0 24 24"><path d="M11 15h2v2h-2v-2m0-8h2v6h-2V7m1-5C6.47 2 2 6.47 2 12s4.47 10 10 10 10-4.47 10-10S17.53 2 12 2m0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/></svg>
            </div>
            <h2 class="text-2xl font-bold text-white mb-4">What's New in v0.1.1</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <a href="/en/docs/guides/fusion" class="group p-4 rounded-xl bg-white/5 border border-white/10 hover:border-purple-500/50 transition-all">
                    <h3 class="text-purple-400 font-bold mb-1 group-hover:translate-x-1 transition-transform">🧬 Native Fusion</h3>
                    <p class="text-xs text-slate-400 leading-relaxed text-left">The power of NW.js-style unified context, now in Ionyx. Sync state between Rust and JS instantly.</p>
                </a>
                <a href="/en/docs/guides/webgpu" class="group p-4 rounded-xl bg-white/5 border border-white/10 hover:border-emerald-500/50 transition-all text-left">
                    <h3 class="text-emerald-400 font-bold mb-1 group-hover:translate-x-1 transition-transform text-left">🎮 WebGPU Native</h3>
                    <p class="text-xs text-slate-400 leading-relaxed text-left">Next-gen graphics. Every template updated with WebGPU support. Performance is no longer a choice.</p>
                </a>
            </div>
          </section>

          <section id="comparison" class="scroll-mt-32 mb-24">
            <h2 id="ecosystem-comparison" aria-labelledby="ecosystem-comparison" class="text-3xl font-bold text-white mb-8 tracking-tight">Ecosystem Comparison</h2>
            <div class="overflow-hidden bg-slate-800/20 rounded-2xl border border-slate-800">
              <table class="w-full text-left border-collapse">
                <thead>
                  <tr class="bg-slate-800/50 text-white text-sm">
                    <th class="p-4 border-b border-slate-700 font-bold uppercase tracking-wider text-[10px] opacity-60">Metric</th>
                    <th class="p-4 border-b border-slate-700 text-purple-400 font-black italic">IONYX</th>
                    <th class="p-4 border-b border-slate-700 opacity-80 font-semibold">Tauri™</th>
                    <th class="p-4 border-b border-slate-700 opacity-80 font-semibold">Electron™</th>
                  </tr>
                </thead>
                <tbody class="text-sm">
                  <tr class="border-b border-slate-800/30 hover:bg-white/[0.02] transition-colors">
                    <td class="p-4 font-semibold text-slate-400 tracking-tight">Base Binary Size</td>
                    <td class="p-4 text-emerald-400 font-bold">1.5 MB</td>
                    <td class="p-4">~3.1 MB</td>
                    <td class="p-4 text-red-400">85+ MB</td>
                  </tr>
                  <tr class="border-b border-slate-800/30 hover:bg-white/[0.02] transition-colors">
                    <td class="p-4 font-semibold text-slate-400 tracking-tight">Memory Footprint</td>
                    <td class="p-4 text-emerald-400 font-bold">~24 MB</td>
                    <td class="p-4">~32 MB</td>
                    <td class="p-4">~160 MB</td>
                  </tr>
                  <tr class="border-b border-slate-800/30 hover:bg-white/[0.02] transition-colors">
                    <td class="p-4 font-semibold text-slate-400 tracking-tight">Build Engine</td>
                    <td class="p-4 font-bold text-slate-200">Rust + WRY + TAO</td>
                    <td class="p-4">Rust + WRY</td>
                    <td class="p-4">Node.js / V8</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </section>

          <section id="installation" class="scroll-mt-32 mb-24">
            <h2 id="getting-started" aria-labelledby="getting-started" class="text-3xl font-bold text-white mb-8 tracking-tight">Getting Started</h2>
            <p class="mb-6">Deploy the Ionyx CLI to your environment via your preferred package manager.</p>
            <div class="p-6 bg-black/40 rounded-2xl border border-slate-800 shadow-2xl backdrop-blur-sm">
              <div class="flex items-center gap-1.5 mb-6 border-b border-slate-800 pb-4">
                <div class="w-3 h-3 rounded-full bg-slate-700"></div>
                <div class="w-3 h-3 rounded-full bg-slate-700"></div>
                <div class="w-3 h-3 rounded-full bg-slate-700"></div>
                <span class="ml-2 text-[10px] text-slate-500 font-mono">zsh — ionyx-install</span>
              </div>
              <pre class="text-sm font-mono leading-relaxed"><code class="text-emerald-400">npm install -g ionyx</code></pre>
            </div>
          </section>

          <footer id="trademarks" class="scroll-mt-32 pt-20 border-t border-slate-800/50">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12 text-[11px] leading-relaxed opacity-50">
                <div>
                    <h4 class="text-white font-bold mb-4 uppercase tracking-[0.2em]">Trademark Legal Notice</h4>
                    <p class="mb-4 text-justify">
                      Ionyx is an independent open-source project. **TAURI™** is a trademark of The Tauri Programme within the Commons Conservancy. **ELECTRON™** is a trademark of the OpenJS Foundation. 
                    </p>
                </div>
                <div>
                    <h4 class="text-white font-bold mb-4 uppercase tracking-[0.2em]">Ownership</h4>
                    <p class="mb-6 italic text-justify">
                      All other content, including the Ionyx brand, logo, and core architecture, is developed by the Ionyx Apps team.
                    </p>
                    <p class="text-white font-medium">
                      2026 Ionyx Apps and Contributors. All rights reserved.
                    </p>
                </div>
            </div>
          </footer>

        </article>
      </main>

      <aside class="hidden xl:block w-64 fixed right-[max(0px,calc(50%-720px))] h-screen pt-24 pb-10 px-8">
        <h5 class="text-white font-bold mb-6 text-[10px] uppercase tracking-[0.2em] opacity-40">On This Page</h5>
        <nav class="space-y-4 text-xs font-medium">
          <a href="#comparison" class="block text-slate-500 hover:text-white transition-all">Ecosystem Comparison</a>
          <a href="#installation" class="block text-slate-500 hover:text-white transition-all">Quick Start</a>
          <a href="#trademarks" class="block text-slate-500 hover:text-white transition-all">Trademark & Legal</a>
        </nav>
      </aside>

    </div>
  </div>
</BaseLayout>